#!/usr/bin/env zunit

@test 'verify vim version' {
    run bash -c "vim --version | head -1 | cut -d ' ' -f 5 | cut -d '.' -f 1"
    assert $output is_greater_than 7
}

@test 'verify python version matches default' {
    DEFAULT_PYTHON_VERSION=$(grep '^DEFAULT_PYTHON_VERSION=' install/python.sh | cut -d '=' -f 2 | tr -d '"' | cut -d '.' -f 1,2)
    run bash -c "python --version | cut -d ' ' -f 2 | cut -d '.' -f 1,2"
    assert "$output" same_as "$DEFAULT_PYTHON_VERSION"
}
