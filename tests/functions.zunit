#!/usr/bin/env zunit

@setup {
    fpath=($DOTFILES_DIR/etc/zsh/functions $fpath)
    autoload -Uz calc get_trunk_branch git
}

@test 'calc' {
    run calc 1 + 2
    assert $output equals 3
}

@test 'get_trunk_branch' {
    run get_trunk_branch
    assert $output equals main
}

@test 'git checkout blocked' {
    run git checkout main
    assert $state equals 1
    assert $output contains "Don't use checkout"
}
