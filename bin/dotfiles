#!/usr/bin/env bash

# ---------------------------------------------------------------
# The dotfiles command - a unified interface for managing dotfiles
# This script provides various subcommands for common dotfiles tasks:
# - Updating packages and configurations
# - Applying system settings
# - Running tests
# - Cleaning up caches
# ---------------------------------------------------------------

BIN_NAME=$(basename "$0")
COMMAND_NAME=$1
SUBCOMMAND_NAME=$2

# Source shared logging helpers (log_debug/info/warning/error, print_section_header)
source "${DOTFILES_DIR}/install/utils.sh"

# Display help information about available commands
sub_help() {
    echo "Usage: $BIN_NAME <command> [subcommand] [options]"
    echo
    echo "Commands:"
    echo "   analysis-status      Show analysis report status for \$PROJECTS_DIR"
    echo "   clean                Clean up caches (brew, apt, gem, vim plugins)"
    echo "   drift-check          Check steering docs for broken references"
    echo "   edit                 Open dotfiles in IDE ($DOTFILES_IDE)"
    echo "   help                 This help message"
    echo "   mac                  macOS specific commands (see below)"
    echo "   orphans              Find packages installed but not tracked in dotfiles"
    echo "   sync-projects        Fetch and fast-forward \$PROJECTS_DIR repositories"
    echo "   sync-sources         Fetch and reset \$SOURCES_DIR repositories"
    echo "   test                 Run tests"
    echo "   update               Update packages and pkg managers (OS, brew, apt)"
    echo
    echo "Mac Commands:"
    echo "   mac apps             Install macOS applications"
    echo "   mac defaults         Apply macOS system defaults"
    echo "   mac dock personal    Apply personal macOS Dock settings"
    echo "   mac dock work        Apply work macOS Dock settings"
    echo
    echo "Options:"
    echo "   --debug              Set log level to debug"
    echo "   --quiet              Set log level to error (only show errors)"
    echo "   --silent             Set log level to none (show no output)"
    echo
    echo "Examples:"
    echo "   $BIN_NAME update     Update all packages and package managers"
    echo "   $BIN_NAME clean      Clean up package caches"
    echo "   $BIN_NAME mac dock personal  Configure personal dock layout"
    echo "   $BIN_NAME --debug update  Run update with debug logging"
}

# Open the dotfiles directory in the configured IDE
sub_edit() {
    log_info "Opening dotfiles in $DOTFILES_IDE"
    sh -c "cd $DOTFILES_DIR && $DOTFILES_IDE"
}

# Run the test suite to verify dotfiles functionality
sub_test() {
    log_info "Running tests in $DOTFILES_DIR/tests/"
    cd "$DOTFILES_DIR" && zunit "$DOTFILES_DIR"/tests/
}

# Update all packages and package managers
sub_update() {
    log_info "Starting update process"
    export HOMEBREW_NO_ENV_HINTS=1

    # macOS-specific updates
    if is-macos; then
        # Only update Mac App Store apps on personal computers
        if ! is-work; then
            print_section_header "Updating Mac App Store applications"
            log_debug "Running: mas upgrade"
            mas upgrade
        else
            log_debug "Skipping Mac App Store updates on work computer"
        fi

        print_section_header "Upgrading Homebrew packages"
        local brew_outdated
        brew_outdated=$(brew outdated --verbose 2>/dev/null) || true
        # shellcheck disable=SC2034
        local brew_output
        run_and_capture brew_output brew upgrade
        local -a brew_upgraded=()
        while IFS= read -r line; do
            [[ -n "$line" ]] && brew_upgraded+=("$line")
        done <<<"$brew_outdated"
        print_update_summary "Homebrew" "packages" "${brew_upgraded[@]}"
    fi

    # Debian-specific updates
    if is-debian; then
        print_section_header "Running apt update & upgrade"
        log_debug "Running: sudo apt update"
        sudo apt update
        log_debug "Running: sudo apt upgrade -y"
        sudo apt upgrade -y

        print_section_header "Running snap refresh"
        log_debug "Running: sudo snap refresh"
        sudo snap refresh
    fi

    # Update language-specific package managers and tools
    print_section_header "Updating antidote"
    PATH="$ZDOTDIR/.antidote/":$PATH
    local antidote_output
    run_and_capture antidote_output antidote update
    local -a antidote_updated=()
    while IFS= read -r line; do
        local clean
        clean=$(echo "$line" | strip_ansi)
        if [[ "$clean" =~ ^antidote:\ updated:\ ([^ ]+) ]]; then
            antidote_updated+=("${BASH_REMATCH[1]}")
        fi
    done <<<"$antidote_output"
    print_update_summary "antidote" "plugins" "${antidote_updated[@]}"

    print_section_header "Updating pyenv"
    local pyenv_output
    run_and_capture pyenv_output pyenv update
    local -a pyenv_updated=()
    local current_component=""
    while IFS= read -r line; do
        local clean
        clean=$(echo "$line" | strip_ansi)
        if [[ "$clean" =~ ^Updating.*/([^/]+)\.\.\.$ ]]; then
            current_component="${BASH_REMATCH[1]}"
        elif [[ -n "$current_component" && "$clean" != "Already up to date." && "$clean" =~ ^[0-9a-f]+\.\.[0-9a-f]+ ]]; then
            pyenv_updated+=("$current_component")
            current_component=""
        fi
    done <<<"$pyenv_output"
    print_update_summary "pyenv" "components" "${pyenv_updated[@]}"

    print_section_header "Upgrading global Python packages"
    for python_version in $(pyenv versions --bare); do
        before=$(PYENV_VERSION="$python_version" pip list --format=json 2>/dev/null)
        PYENV_VERSION="$python_version" pip install --upgrade --quiet -r "$DOTFILES_DIR/etc/python/default-packages" 2>/dev/null
        after=$(PYENV_VERSION="$python_version" pip list --format=json 2>/dev/null)
        upgraded=$(PYENV_VERSION="$python_version" python -c "import sys,json;b={p['name']:p['version'] for p in json.loads(sys.argv[1])};a={p['name']:p['version'] for p in json.loads(sys.argv[2])};[print(f'  ✓ {n} {b[n]} → {a[n]}') for n in sorted(a) if n in b and b[n]!=a[n]]" "$before" "$after")
        if [[ -z "$upgraded" ]]; then
            echo -e "\033[32m✓ Python $python_version: all packages up to date\033[0m"
        else
            echo "Python $python_version: upgraded packages:"
            echo "$upgraded"
        fi
    done

    print_section_header "Updating rbenv"
    local rbenv_output
    run_and_capture rbenv_output rbenv update --verbose
    local -a rbenv_updated=()
    local current_component=""
    while IFS= read -r line; do
        if [[ "$line" =~ ^Updating\ (.+)$ ]]; then
            current_component="${BASH_REMATCH[1]}"
        elif [[ -n "$current_component" && "$line" == *"Already up to date."* ]]; then
            current_component=""
        elif [[ -n "$current_component" && "$line" =~ ^\  ]]; then
            rbenv_updated+=("$current_component")
            current_component=""
        fi
    done <<<"$rbenv_output"
    print_update_summary "rbenv" "components" "${rbenv_updated[@]}"

    if is-executable gem; then
        print_section_header "Updating Ruby gems"
        # shellcheck disable=SC2034
        local gem_system_output
        run_and_capture gem_system_output gem update --system --no-document

        local gem_output
        run_and_capture gem_output gem update --no-document
        local -a gem_updated=()
        while IFS= read -r line; do
            if [[ "$line" =~ ^Successfully\ installed\ (.+)$ ]]; then
                gem_updated+=("${BASH_REMATCH[1]}")
            fi
        done <<<"$gem_output"
        print_update_summary "Ruby gems" "gems" "${gem_updated[@]}"
    fi

    print_section_header "Updating vim-plug"
    log_debug "Running: vim -i NONE -c \"PlugUpdate\" -c \"qa\""
    if [[ "$LOG_LEVEL" == "debug" ]]; then
        vim -i NONE -c "PlugUpdate" -c "qa"
    else
        vim -es -i NONE -c "PlugUpdate" -c "qa" >/dev/null 2>&1 || true
    fi
    log_debug "Running: vim -es -i NONE -c \"PlugUpgrade\" -c \"qa\""
    vim -es -i NONE -c "PlugUpgrade" -c "qa"

    if is-executable npm; then
        print_section_header "Updating global npm packages"
        local npm_outdated
        npm_outdated=$(npm outdated -g --parseable 2>/dev/null) || true
        # shellcheck disable=SC2034
        local npm_output
        run_and_capture npm_output npm update -g
        local -a npm_updated=()
        while IFS= read -r line; do
            # parseable format: /path/node_modules/pkg:pkg@current:pkg@wanted:pkg@latest
            if [[ "$line" =~ :([^@]+)@([^:]+):([^@]+)@([^:]+): ]]; then
                npm_updated+=("${BASH_REMATCH[1]} ${BASH_REMATCH[2]} → ${BASH_REMATCH[4]}")
            fi
        done <<<"$npm_outdated"
        print_update_summary "npm" "global packages" "${npm_updated[@]}"
    fi

    log_info "Cleaning up"
    sub_clean

    log_info "Update process completed"
}

# Clean up package manager caches and remove unused packages
sub_clean() {
    # macOS cleanup
    if is-macos; then
        print_section_header "Running brew cleanup"
        log_debug "Running: brew cleanup"
        brew cleanup

        print_section_header "Running brew autoremove"
        log_debug "Running: brew autoremove"
        brew autoremove
    fi

    # Debian cleanup
    if is-debian; then
        print_section_header "Running apt clean"
        log_debug "Running: sudo apt clean"
        sudo apt clean

        print_section_header "Running apt autoremove"
        log_debug "Running: sudo apt autoremove"
        sudo apt autoremove
    fi

    if is-executable gem; then
        print_section_header "Cleaning Ruby gems"
        log_debug "Running: gem cleanup"
        gem cleanup
    fi

    # Clean up Vim plugins
    print_section_header "Running PlugClean"
    log_debug "Running: vim -i NONE -c \"PlugClean\" -c \"qa\""
    vim -i NONE -c "PlugClean" -c "qa"

    log_info "Cleanup completed"
}

# macOS namespace command handler
sub_mac() {
    # Check if we're on macOS
    if ! is-macos; then
        log_error "Mac commands are only available on macOS"
        return 1
    fi

    # If no subcommand is provided, show help
    if [[ -z "$SUBCOMMAND_NAME" ]]; then
        log_error "No mac subcommand specified"
        echo "Available mac subcommands:"
        echo "   apps             Install macOS applications"
        echo "   defaults         Apply macOS system defaults"
        echo "   dock personal    Apply personal macOS Dock settings"
        echo "   dock work        Apply work macOS Dock settings"
        return 1
    fi

    # Handle mac subcommands
    case "$SUBCOMMAND_NAME" in
    apps)
        sub_mac_apps "$@"
        ;;
    defaults)
        sub_mac_defaults "$@"
        ;;
    dock)
        shift # Remove 'dock' from arguments
        sub_mac_dock "$@"
        ;;
    *)
        log_error "Unknown mac subcommand: $SUBCOMMAND_NAME"
        echo "Available mac subcommands:"
        echo "   apps             Install macOS applications"
        echo "   defaults         Apply macOS system defaults"
        echo "   dock personal    Apply personal macOS Dock settings"
        echo "   dock work        Apply work macOS Dock settings"
        return 1
        ;;
    esac
}

# Apply macOS system defaults from all defaults-*.sh files
sub_mac_defaults() {
    log_info "Applying macOS system defaults"

    for DEFAULTS_FILE in "${DOTFILES_DIR}"/macos/defaults*.sh; do
        echo "Applying ${DEFAULTS_FILE}"
        log_debug "Sourcing: ${DEFAULTS_FILE}"
        # shellcheck source=SCRIPTDIR/../macos/defaults.sh
        . "${DEFAULTS_FILE}"
    done
    echo "Done. Some changes may require a logout/restart to take effect."
}

# Install macOS applications
sub_mac_apps() {
    log_info "Installing macOS applications"

    log_debug "Sourcing: ${DOTFILES_DIR}/macos/apps.sh"
    . "${DOTFILES_DIR}/macos/apps.sh"
}

# Handle dock subcommands
sub_mac_dock() {
    local dock_type="$1"

    if [[ -z "$dock_type" ]]; then
        log_error "No dock type specified"
        echo "Available dock types:"
        echo "   personal    Apply personal macOS Dock settings"
        echo "   work        Apply work macOS Dock settings"
        return 1
    fi

    case "$dock_type" in
    personal)
        sub_mac_dock_personal
        ;;
    work)
        sub_mac_dock_work
        ;;
    *)
        log_error "Unknown dock type: $dock_type"
        echo "Available dock types:"
        echo "   personal    Apply personal macOS Dock settings"
        echo "   work        Apply work macOS Dock settings"
        return 1
        ;;
    esac
}

# Configure the macOS Dock with personal layout
sub_mac_dock_personal() {
    log_info "Configuring personal macOS Dock layout"

    log_debug "Sourcing: ${DOTFILES_DIR}/macos/dock-personal.sh"
    . "${DOTFILES_DIR}/macos/dock-personal.sh" && echo "Dock reloaded."
}

# Configure the macOS Dock with work layout
sub_mac_dock_work() {
    log_info "Configuring work macOS Dock layout"

    log_debug "Sourcing: ${DOTFILES_DIR}/macos/dock-work.sh"
    . "${DOTFILES_DIR}/macos/dock-work.sh" && echo "Dock reloaded."
}

# Check steering docs for broken references (drift detection)
sub_drift-check() {
    log_info "Running drift detection on steering docs"
    bash "${DOTFILES_DIR}/scripts/drift-check.sh"
}

# Fetch and fast-forward project repositories in $PROJECTS_DIR/<owner>/<repo>
sub_sync-projects() {
    print_section_header "Syncing project repositories"

    local projects_dir="${PROJECTS_DIR:-$HOME/projects}"

    if [[ ! -d "$projects_dir" ]]; then
        log_warning "No projects directory found at $projects_dir"
        return 0
    fi

    # Collect results for the summary table
    local repos=()
    local statuses=()
    local details=()

    local GREEN="\033[32m"
    local YELLOW="\033[0;33m"
    local RED="\033[0;31m"
    local BLUE="\033[0;34m"
    local RESET="\033[0m"

    local total=0
    for repo_dir in "$projects_dir"/*/*; do
        [[ -d "$repo_dir/.git" ]] && total=$((total + 1))
    done

    local count=0
    for repo_dir in "$projects_dir"/*/*; do
        [[ -d "$repo_dir/.git" ]] || continue

        local display_path="${repo_dir#"$projects_dir/"}"
        repos+=("$display_path")
        count=$((count + 1))

        printf "\r\033[K  Fetching [%d/%d] %s..." "$count" "$total" "$display_path" >&2

        log_debug "Processing: $display_path"

        # Fetch all remotes
        if ! git -C "$repo_dir" fetch --all --prune --quiet 2>/dev/null; then
            statuses+=("error")
            details+=("fetch failed")
            continue
        fi

        # Detect primary branch
        local primary_branch
        primary_branch=$(git -C "$repo_dir" symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's|refs/remotes/origin/||')
        if [[ -z "$primary_branch" ]]; then
            for candidate in main master; do
                if git -C "$repo_dir" rev-parse --verify "refs/heads/$candidate" &>/dev/null; then
                    primary_branch="$candidate"
                    break
                fi
            done
        fi

        if [[ -z "$primary_branch" ]]; then
            statuses+=("warning")
            details+=("no primary branch detected")
            continue
        fi

        # Check current branch
        local current_branch
        current_branch=$(git -C "$repo_dir" branch --show-current 2>/dev/null)

        if [[ "$current_branch" != "$primary_branch" ]]; then
            statuses+=("skipped")
            details+=("on branch $current_branch")
            continue
        fi

        # Check for dirty working tree
        if [[ -n $(git -C "$repo_dir" status --porcelain 2>/dev/null) ]]; then
            statuses+=("skipped")
            details+=("dirty working tree")
            continue
        fi

        # Check how far behind
        local behind
        behind=$(git -C "$repo_dir" rev-list --count HEAD..origin/"$primary_branch" 2>/dev/null)

        if [[ "$behind" -eq 0 ]]; then
            statuses+=("current")
            details+=("")
            continue
        fi

        # Attempt fast-forward merge
        if git -C "$repo_dir" merge --ff-only origin/"$primary_branch" --quiet 2>/dev/null; then
            statuses+=("updated")
            details+=("$behind commit(s)")
        else
            statuses+=("diverged")
            details+=("$behind behind, cannot fast-forward")
        fi
    done

    if [[ ${#repos[@]} -eq 0 ]]; then
        log_info "No repositories found in $projects_dir"
        return 0
    fi

    # Calculate column widths
    printf "\r\033[K" >&2
    local max_repo=10 max_detail=7
    for i in "${!repos[@]}"; do
        [[ ${#repos[$i]} -gt $max_repo ]] && max_repo=${#repos[$i]}
        [[ ${#details[$i]} -gt $max_detail ]] && max_detail=${#details[$i]}
    done

    # Print table
    echo ""
    local divider
    divider=$(printf '─%.0s' $(seq 1 $((max_repo + max_detail + 20))))
    printf " %-${max_repo}s │ %-11s │ %s\n" "Repository" "Status" "Details"
    echo " $divider"

    for i in "${!repos[@]}"; do
        local color status_str
        # Pad status strings to 11 visual columns
        # ✓/✗ are single-width (1 col), ⏭/⚠ are double-width (2 cols)
        case "${statuses[$i]}" in
        updated)
            color="$GREEN"
            status_str="✓ updated  "
            ;;
        current)
            color="$BLUE"
            status_str="✓ current  "
            ;;
        skipped)
            color="$YELLOW"
            status_str="⏭ skipped "
            ;;
        diverged)
            color="$YELLOW"
            status_str="⚠ diverged"
            ;;
        warning)
            color="$YELLOW"
            status_str="⚠ warning "
            ;;
        error)
            color="$RED"
            status_str="✗ error    "
            ;;
        esac
        printf " %-${max_repo}s │ ${color}%s${RESET} │ %s\n" \
            "${repos[$i]}" "$status_str" "${details[$i]}"
    done

    # Summary counts
    local updated=0 current=0 skipped=0 problems=0
    for s in "${statuses[@]}"; do
        case "$s" in
        updated) updated=$((updated + 1)) ;;
        current) current=$((current + 1)) ;;
        skipped) skipped=$((skipped + 1)) ;;
        diverged | warning | error) problems=$((problems + 1)) ;;
        esac
    done
    echo ""
    echo " ${#repos[@]} repos: ${updated} updated, ${current} current, ${skipped} skipped, ${problems} need attention"
}

# Fetch and reset source repositories in $SOURCES_DIR/<owner>/<repo>
sub_sync-sources() {
    print_section_header "Syncing source repositories"

    local sources_dir="${SOURCES_DIR:-$HOME/sources}"

    if [[ ! -d "$sources_dir" ]]; then
        log_warning "No sources directory found at $sources_dir"
        return 0
    fi

    local repos=()
    local statuses=()
    local details=()

    local GREEN="\033[32m"
    local YELLOW="\033[0;33m"
    local RED="\033[0;31m"
    local BLUE="\033[0;34m"
    local RESET="\033[0m"

    local total=0
    for repo_dir in "$sources_dir"/*/*; do
        [[ -d "$repo_dir/.git" ]] && total=$((total + 1))
    done

    local count=0
    for repo_dir in "$sources_dir"/*/*; do
        [[ -d "$repo_dir/.git" ]] || continue

        local display_path="${repo_dir#"$sources_dir/"}"
        repos+=("$display_path")
        count=$((count + 1))

        printf "\r\033[K  Fetching [%d/%d] %s..." "$count" "$total" "$display_path" >&2

        log_debug "Processing: $display_path"

        # Fetch all remotes
        if ! git -C "$repo_dir" fetch --all --prune --quiet 2>/dev/null; then
            statuses+=("error")
            details+=("fetch failed")
            continue
        fi

        # Detect primary branch
        local primary_branch
        primary_branch=$(git -C "$repo_dir" symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's|refs/remotes/origin/||')
        if [[ -z "$primary_branch" ]]; then
            for candidate in main master; do
                if git -C "$repo_dir" rev-parse --verify "refs/heads/$candidate" &>/dev/null; then
                    primary_branch="$candidate"
                    break
                fi
            done
        fi

        if [[ -z "$primary_branch" ]]; then
            statuses+=("warning")
            details+=("no primary branch detected")
            continue
        fi

        # Warn if there are unexpected local changes
        if [[ -n $(git -C "$repo_dir" status --porcelain 2>/dev/null) ]]; then
            statuses+=("warning")
            details+=("unexpected local changes")
            continue
        fi

        # Check how far behind
        local behind
        behind=$(git -C "$repo_dir" rev-list --count HEAD..origin/"$primary_branch" 2>/dev/null)

        if [[ "$behind" -eq 0 ]]; then
            statuses+=("current")
            details+=("")
            continue
        fi

        # Hard reset to origin — sources should have no local state
        if git -C "$repo_dir" checkout "$primary_branch" --quiet 2>/dev/null &&
            git -C "$repo_dir" reset --hard origin/"$primary_branch" --quiet 2>/dev/null; then
            statuses+=("updated")
            details+=("$behind commit(s)")
        else
            statuses+=("error")
            details+=("reset failed")
        fi
    done

    if [[ ${#repos[@]} -eq 0 ]]; then
        log_info "No repositories found in $sources_dir"
        return 0
    fi

    # Calculate column widths
    printf "\r\033[K" >&2
    local max_repo=10 max_detail=7
    for i in "${!repos[@]}"; do
        [[ ${#repos[$i]} -gt $max_repo ]] && max_repo=${#repos[$i]}
        [[ ${#details[$i]} -gt $max_detail ]] && max_detail=${#details[$i]}
    done

    # Print table
    echo ""
    local divider
    divider=$(printf '─%.0s' $(seq 1 $((max_repo + max_detail + 20))))
    printf " %-${max_repo}s │ %-11s │ %s\n" "Repository" "Status" "Details"
    echo " $divider"

    for i in "${!repos[@]}"; do
        local color status_str
        case "${statuses[$i]}" in
        updated)
            color="$GREEN"
            status_str="✓ updated  "
            ;;
        current)
            color="$BLUE"
            status_str="✓ current  "
            ;;
        warning)
            color="$YELLOW"
            status_str="⚠ warning "
            ;;
        error)
            color="$RED"
            status_str="✗ error    "
            ;;
        esac
        printf " %-${max_repo}s │ ${color}%s${RESET} │ %s\n" \
            "${repos[$i]}" "$status_str" "${details[$i]}"
    done

    # Summary counts
    local updated=0 current=0 problems=0
    for s in "${statuses[@]}"; do
        case "$s" in
        updated) updated=$((updated + 1)) ;;
        current) current=$((current + 1)) ;;
        warning | error) problems=$((problems + 1)) ;;
        esac
    done
    echo ""
    echo " ${#repos[@]} repos: ${updated} updated, ${current} current, ${problems} need attention"
}

# Show analysis report status for project repositories
sub_analysis-status() {
    local projects_dir="${PROJECTS_DIR:-$HOME/projects}"

    if [[ ! -d "$projects_dir" ]]; then
        log_warning "No projects directory found at $projects_dir"
        return 0
    fi

    local GREEN="\033[32m"
    local YELLOW="\033[0;33m"
    local RED="\033[0;31m"
    local BLUE="\033[0;34m"
    local DIM="\033[2m"
    local RESET="\033[0m"

    # Analysis files in dependency order
    local analysis_names=(project architecture schema integration documentation testing technical-debt performance security)
    local analysis_letters=(P A S I D T X F E)

    local repos=()
    local drifts=()
    local -a all_flags=()

    for repo_dir in "$projects_dir"/*/*; do
        [[ -d "$repo_dir/.git" ]] || continue

        local display_path="${repo_dir#"$projects_dir/"}"
        repos+=("$display_path")

        local analysis_dir="$repo_dir/analysis"
        local drift=""
        local flags=()
        local repo_head
        repo_head=$(git -C "$repo_dir" rev-parse HEAD 2>/dev/null)

        for name in "${analysis_names[@]}"; do
            local file="$analysis_dir/${name}-analysis.md"
            if [[ -f "$file" ]]; then
                local analysis_commit
                analysis_commit=$(grep -m1 '^\*\*HEAD Commit:\*\*' "$file" 2>/dev/null | awk '{print $NF}')
                if [[ "$analysis_commit" == "$repo_head" ]]; then
                    flags+=("current")
                else
                    flags+=("stale")
                fi
                # Get drift from project-analysis (the foundation)
                if [[ "$name" == "project" && -n "$analysis_commit" ]]; then
                    drift=$(git -C "$repo_dir" rev-list --count "$analysis_commit"..HEAD 2>/dev/null || echo "?")
                fi
            else
                flags+=("no")
            fi
        done

        drifts+=("$drift")
        all_flags+=("${flags[*]}")
    done

    if [[ ${#repos[@]} -eq 0 ]]; then
        log_info "No repositories found in $projects_dir"
        return 0
    fi

    # Calculate repo column width
    local max_repo=10
    for r in "${repos[@]}"; do
        [[ ${#r} -gt $max_repo ]] && max_repo=${#r}
    done

    # Print table
    echo ""
    local header_cols=""
    for l in "${analysis_letters[@]}"; do
        header_cols+="  $l"
    done
    local divider
    divider=$(printf '─%.0s' $(seq 1 $((max_repo + 36))))
    printf " %-${max_repo}s │ %5s │%s\n" "Repository" "Drift" "$header_cols"
    echo " $divider"

    for i in "${!repos[@]}"; do
        local drift_display="${drifts[$i]}"
        local drift_color="$RESET"
        if [[ -z "$drift_display" ]]; then
            drift_display="    -"
            drift_color="$DIM"
        elif [[ "$drift_display" == "0" ]]; then
            drift_color="$GREEN"
            drift_display=$(printf "%5s" "$drift_display")
        elif [[ "$drift_display" -le 20 ]]; then
            drift_color="$BLUE"
            drift_display=$(printf "%5s" "$drift_display")
        elif [[ "$drift_display" -le 100 ]]; then
            drift_color="$YELLOW"
            drift_display=$(printf "%5s" "$drift_display")
        else
            drift_color="$RED"
            drift_display=$(printf "%5s" "$drift_display")
        fi

        local flag_str=""
        read -ra flags_arr <<<"${all_flags[$i]}"
        for f in "${flags_arr[@]}"; do
            if [[ "$f" == "current" ]]; then
                flag_str+="  ${GREEN}✓${RESET}"
            elif [[ "$f" == "stale" ]]; then
                flag_str+="  ${YELLOW}◐${RESET}"
            else
                flag_str+="  ${DIM}·${RESET}"
            fi
        done

        printf " %-${max_repo}s │ ${drift_color}%s${RESET} │%b\n" \
            "${repos[$i]}" "$drift_display" "$flag_str"
    done

    # Summary
    local total=${#repos[@]} with_any=0 complete=0 none=0
    for i in "${!repos[@]}"; do
        read -ra flags_arr <<<"${all_flags[$i]}"
        local count=0
        for f in "${flags_arr[@]}"; do
            [[ "$f" == "current" || "$f" == "stale" ]] && count=$((count + 1))
        done
        if [[ $count -eq 9 ]]; then
            complete=$((complete + 1))
        elif [[ $count -gt 0 ]]; then
            with_any=$((with_any + 1))
        else
            none=$((none + 1))
        fi
    done
    echo ""
    echo " $total repos: $complete complete, $with_any partial, $none none"
    echo ""
    echo " Core:  P = project         Deep:  D = documentation"
    echo "        A = architecture           T = testing"
    echo "        S = schema                 X = tech-debt"
    echo "        I = integration            F = performance"
    echo "                                   E = security"
    echo ""
    echo " ✓ = current  ◐ = stale  · = missing"
    echo ""
    echo " Drift: commits since last project-analysis (— = no analysis)"
}

# Check for orphaned packages not tracked in dotfiles
sub_orphans() {
    log_info "Checking for orphaned packages"

    local GREEN="\033[32m"
    local YELLOW="\033[0;33m"
    local RESET="\033[0m"
    local found_orphans=0

    # --- npm global packages ---
    if is-executable npm; then
        print_section_header "npm global packages"
        local -a npm_tracked=()
        # From default-packages
        if [[ -f "$DOTFILES_DIR/etc/node/default-packages" ]]; then
            while IFS= read -r line; do
                [[ -n "$line" && "$line" != \#* ]] && npm_tracked+=("$line")
            done <"$DOTFILES_DIR/etc/node/default-packages"
        fi
        # From mcp-servers.conf
        if [[ -f "$DOTFILES_DIR/etc/kiro-cli/mcp-servers.conf" ]]; then
            # shellcheck source=SCRIPTDIR/../etc/kiro-cli/mcp-servers.conf
            source "$DOTFILES_DIR/etc/kiro-cli/mcp-servers.conf"
            npm_tracked+=("${NODE_MCP_SERVERS[@]}")
        fi

        local -a npm_installed=()
        while IFS= read -r pkg; do
            [[ -n "$pkg" ]] && npm_installed+=("$pkg")
        done < <(npm list -g --depth=0 --json 2>/dev/null | jq -r '.dependencies | keys[]' 2>/dev/null)

        local -a npm_orphans=()
        for pkg in "${npm_installed[@]}"; do
            local tracked=false
            for t in "${npm_tracked[@]}"; do
                [[ "$pkg" == "$t" ]] && tracked=true && break
            done
            $tracked || npm_orphans+=("$pkg")
        done

        if [[ ${#npm_orphans[@]} -eq 0 ]]; then
            echo -e "${GREEN}✓ No orphaned npm packages${RESET}"
        else
            found_orphans=1
            echo -e "${YELLOW}Orphaned npm packages (not in default-packages or mcp-servers.conf):${RESET}"
            for pkg in "${npm_orphans[@]}"; do
                echo "  - $pkg"
            done
            echo "  Run: npm uninstall -g ${npm_orphans[*]}"
        fi
    fi

    # --- pip packages (per pyenv version) ---
    if is-executable pyenv; then
        print_section_header "pip packages"

        for python_version in $(pyenv versions --bare); do
            # Use Python to resolve full dependency tree including extras
            local -a pip_orphans=()
            while IFS= read -r pkg; do
                [[ -n "$pkg" ]] && pip_orphans+=("$pkg")
            done < <(PYENV_VERSION="$python_version" python "$DOTFILES_DIR/scripts/pip_orphans.py" \
                "$DOTFILES_DIR/etc/python/default-packages" 2>/dev/null)

            if [[ ${#pip_orphans[@]} -eq 0 ]]; then
                echo -e "${GREEN}✓ Python $python_version: no orphaned packages${RESET}"
            else
                found_orphans=1
                echo -e "${YELLOW}Python $python_version: orphaned packages (not in default-packages):${RESET}"
                for pkg in "${pip_orphans[@]}"; do
                    echo "  - $pkg"
                done
            fi
        done
    fi

    # --- Ruby gems ---
    if is-executable gem; then
        print_section_header "Ruby gems"
        local -a gem_orphans=()
        while IFS= read -r pkg; do
            [[ -n "$pkg" ]] && gem_orphans+=("$pkg")
        done < <(ruby "$DOTFILES_DIR/scripts/gem_orphans.rb" \
            "$DOTFILES_DIR/etc/ruby/default-gems" 2>/dev/null)

        if [[ ${#gem_orphans[@]} -eq 0 ]]; then
            echo -e "${GREEN}✓ No orphaned gems${RESET}"
        else
            found_orphans=1
            echo -e "${YELLOW}Orphaned gems (not in default-gems or their dependencies):${RESET}"
            for pkg in "${gem_orphans[@]}"; do
                echo "  - $pkg"
            done
        fi
    fi

    # --- Homebrew ---
    if is-executable brew; then
        print_section_header "Homebrew packages"
        # Build tracked list from all install scripts
        local -a brew_tracked=()
        while IFS= read -r pkg; do
            [[ -n "$pkg" ]] && brew_tracked+=("$pkg")
        done < <(grep -h 'install_if_needed' "$DOTFILES_DIR"/install/brew.sh 2>/dev/null |
            sed -E 's/.*install_if_needed "([^"]+)".*/\1/')
        # Also grab direct brew install calls from other scripts
        while IFS= read -r pkg; do
            [[ -n "$pkg" ]] && brew_tracked+=("$pkg")
        done < <(grep -rh 'brew install' "$DOTFILES_DIR"/install/*.sh 2>/dev/null |
            grep -v 'install_if_needed\|NONINTERACTIVE\|^#\|^ *#' |
            sed -E 's/.*brew install (--formula |--cask )?//' | tr -d '"' |
            tr ' ' '\n' | grep -v '^-\|^\$\|^$')

        # Formulae leaves (user-intentional, not pulled in as deps)
        local -a brew_orphans=()
        while IFS= read -r pkg; do
            local tracked=false
            local short_pkg="${pkg##*/}" # strip tap prefix (e.g. tap/name -> name)
            for t in "${brew_tracked[@]}"; do
                [[ "$pkg" == "$t" || "$short_pkg" == "$t" ]] && tracked=true && break
            done
            $tracked || brew_orphans+=("$pkg")
        done < <(brew leaves 2>/dev/null)

        # Casks
        local -a cask_orphans=()
        while IFS= read -r pkg; do
            local tracked=false
            for t in "${brew_tracked[@]}"; do
                [[ "$pkg" == "$t" ]] && tracked=true && break
            done
            $tracked || cask_orphans+=("$pkg")
        done < <(brew list --cask 2>/dev/null)

        if [[ ${#brew_orphans[@]} -eq 0 && ${#cask_orphans[@]} -eq 0 ]]; then
            echo -e "${GREEN}✓ No orphaned Homebrew packages${RESET}"
        else
            found_orphans=1
            if [[ ${#brew_orphans[@]} -gt 0 ]]; then
                echo -e "${YELLOW}Orphaned formulae (not in install scripts):${RESET}"
                for pkg in "${brew_orphans[@]}"; do
                    echo "  - $pkg"
                done
            fi
            if [[ ${#cask_orphans[@]} -gt 0 ]]; then
                echo -e "${YELLOW}Orphaned casks (not in install scripts):${RESET}"
                for pkg in "${cask_orphans[@]}"; do
                    echo "  - $pkg"
                done
            fi
        fi
    fi

    if [[ $found_orphans -eq 0 ]]; then
        echo ""
        log_info "All packages are tracked — no orphans found"
    fi
}

# Shell completion for available commands
# Make sure to keep this in sync with the available public commands
sub_completion() {
    echo "analysis-status clean drift-check edit help mac orphans sync-projects sync-sources test update"
}

# Process global options
# LOG_LEVEL is defined in sourced utils.sh and read by its log_* functions
# shellcheck disable=SC2034
process_options() {
    case "$1" in
    --debug)
        LOG_LEVEL="debug"
        return 1
        ;;
    --quiet)
        LOG_LEVEL="error"
        return 1
        ;;
    --silent)
        LOG_LEVEL="none"
        return 1
        ;;
    *)
        return 0
        ;;
    esac
}

# Process command line arguments
while ! process_options "$COMMAND_NAME"; do
    shift
    COMMAND_NAME=$1
done

# Process trailing options (supports both "dotfiles --debug update" and "dotfiles update --debug")
for arg in "$@"; do
    process_options "$arg"
done

# Command dispatcher
case $COMMAND_NAME in
"" | "-h" | "--help")
    sub_help
    ;;
*)
    shift
    if declare -f "sub_${COMMAND_NAME}" >/dev/null; then
        "sub_${COMMAND_NAME}" "$@"
    else
        log_error "'$COMMAND_NAME' is not a known command or has errors."
        sub_help
        exit 1
    fi
    ;;
esac

# For backward compatibility
# These functions are kept for backward compatibility with existing scripts
# They will be removed in a future version

sub_mac-defaults() {
    log_warning "The command 'mac-defaults' is deprecated. Please use 'mac defaults' instead."
