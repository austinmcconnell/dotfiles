# Decrypt sops-encrypted secrets and export them as environment variables
# Usage: decrypt-secrets [file]
# Default file: ~/.dotfiles/etc/secrets/tokens.enc.yaml

local secrets_file="${1:-$DOTFILES_DIR/etc/secrets/tokens.enc.yaml}"

if [[ ! -f "$secrets_file" ]]; then
    echo "No secrets file found: $secrets_file" >&2
    return 1
fi

eval "$(sops decrypt --output-type dotenv "$secrets_file" 2>/dev/null | while IFS='=' read -r key value; do
    echo "export ${key}=${value}"
done)"
