fc -l -t '%Y-%m-%d %H:%M:%S' "${@:--50}" | while IFS= read -r line; do
    if [[ "$line" =~ '^( *[0-9]+)  ([0-9]{4}-[0-9]{2}-[0-9]{2} [0-9]{2}:[0-9]{2}:[0-9]{2})  (.*)$' ]]; then
        printf '\e[33m%s\e[0m  \e[36m%s\e[0m  %s\n' "${match[1]}" "${match[2]}" "${match[3]}"
    else
        printf '%s\n' "$line"
    fi
done
