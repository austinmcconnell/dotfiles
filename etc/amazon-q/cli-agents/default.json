{
    "allowedTools": [
        "fs_read",
        "@filesystem/read_text_file",
        "@filesystem/read_multiple_files",
        "@filesystem/list_directory",
        "@filesystem/list_allowed_directories",
        "@filesystem/search_files",
        "@filesystem/get_file_info",
        "@filesystem/directory_tree",
        "@sequential-thinking/sequentialthinking",
        "@git/git_status",
        "@git/git_log",
        "@git/git_diff",
        "@time/get_current_time",
        "@time/get_timezone",
        "@time/format_time",
        "@fetch/fetch_url",
        "@postgres/query"
    ],
    "description": "Default CLI agent configuration",
    "hooks": {
        "agentSpawn": [],
        "userPromptSubmit": []
    },
    "mcpServers": {
        "filesystem": {
            "command": "npx",
            "args": [
                "@modelcontextprotocol/server-filesystem",
                "~/.dotfiles",
                "."
            ],
            "env": {},
            "timeout": 120000,
            "disabled": false
        },
        "sequential-thinking": {
            "command": "npx",
            "args": [
                "@modelcontextprotocol/server-sequential-thinking"
            ],
            "env": {},
            "timeout": 300000,
            "disabled": false
        },
        "git": {
            "command": "python",
            "args": [
                "-m", "mcp_server_git",
                "--repository", "."
            ],
            "env": {},
            "timeout": 120000,
            "disabled": false
        },
        "time": {
            "command": "python",
            "args": [
                "-m", "mcp_server_time",
                "--local-timezone=America/Chicago"
            ],
            "env": {},
            "timeout": 30000,
            "disabled": false
        },
        "fetch": {
            "command": "python",
            "args": [
                "-m", "mcp_server_fetch"
            ],
            "env": {},
            "timeout": 120000,
            "disabled": false
        },
        "postgres": {
            "command": "npx",
            "args": [
                "enhanced-postgres-mcp-server",
                "postgresql://localhost:5432/postgres"
            ],
            "env": {},
            "timeout": 120000,
            "disabled": false
        }
    },
    "name": "default",
    "prompt": null,
    "resources": [
        "file://~/.dotfiles/etc/amazon-q/global_rules/**/*.md",
        "file://.amazonq/rules/**/*.md",
        "file://README.md",
        "file://docs/**/*.md"
    ],
    "toolAliases": {},
    "tools": [
        "*"
    ],
    "toolsSettings": {},
    "useLegacyMcpJson": true
}
