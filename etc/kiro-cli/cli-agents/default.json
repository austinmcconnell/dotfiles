{
    "allowedTools": [
        "@filesystem/create_directory",
        "@filesystem/get_file_info",
        "@filesystem/list_allowed_directories",
        "@filesystem/read_media_file",
        "@filesystem/read_multiple_files",
        "@filesystem/read_text_file",
        "@filesystem/search_files",
        "@git/git_branch",
        "@git/git_diff",
        "@git/git_diff_staged",
        "@git/git_diff_unstaged",
        "@git/git_log",
        "@git/git_show",
        "@git/git_status",
        "fs_read",
        "glob",
        "grep",
        "use_subagent",
        "web_fetch",
        "web_search"
    ],
    "description": "Default CLI agent with comprehensive development tools and security restrictions",
    "hooks": {
        "agentSpawn": [
            {
                "command": "git status --short --branch 2>/dev/null || echo 'Not a git repository'"
            }
        ],
        "preToolUse": [
            {
                "matcher": "*",
                "command": "~/.dotfiles/etc/kiro-cli/hooks/block-env-files.sh"
            },
            {
                "matcher": "use_aws",
                "command": "jq -c '{timestamp: now | strftime(\"%Y-%m-%d %H:%M:%S\"), tool: .tool_name, input: .tool_input}' >> ~/.kiro/logs/aws-audit.jsonl"
            },
            {
                "matcher": "@kubernetes",
                "command": "jq -c '{timestamp: now | strftime(\"%Y-%m-%d %H:%M:%S\"), tool: .tool_name, input: .tool_input}' >> ~/.kiro/logs/kubectl-audit.jsonl"
            },
            {
                "matcher": "execute_bash",
                "command": "~/.dotfiles/etc/kiro-cli/hooks/audit-shell-commands.sh"
            }
        ]
    },
    "includeMcpJson": true,
    "name": "default",
    "prompt": "file://./default-prompt.md",
    "resources": [
        "file://AGENTS.md",
        "file://~/.dotfiles/etc/kiro-cli/steering/workflow/**/*.md",
        "file://~/.dotfiles/etc/kiro-cli/steering/code/**/*.md",
        "file://~/.dotfiles/etc/kiro-cli/steering/security/**/*.md",
        "file://.kiro/steering/**/*.md",
        "file://README.md",
        "skill://.kiro/skills/development/**/SKILL.md",
        "skill://.kiro/skills/operations/**/SKILL.md",
        "skill://.kiro/skills/shared/**/SKILL.md",
        "skill://~/.kiro/skills/development/**/SKILL.md",
        "skill://~/.kiro/skills/operations/**/SKILL.md",
        "skill://~/.kiro/skills/shared/**/SKILL.md"
    ],
    "tools": [
        "*"
    ],
    "toolsSettings": {
        "shell": {
            "allowedCommands": [
                "awk .*",
                "cat .*",
                "cd .*",
                "command -v .*",
                "git branch.*",
                "git diff.*",
                "git log.*",
                "git show.*",
                "git status.*",
                "grep .*",
                "head .*",
                "hostname",
                "ls( .*)?",
                "man .*",
                "pwd",
                "sed .*",
                "sort .*",
                "tail .*",
                "type .*",
                "uniq .*",
                "wc .*",
                "which .*",
                "whoami"
            ],
            "deniedCommands": [
                "awk .*\\.env.*",
                "cat .*\\.env.*",
                "grep .*\\.env.*",
                "head .*\\.env.*",
                "sed .*\\.env.*",
                "tail .*\\.env.*",
                "chmod .*",
                "chown .*",
                "cp /.*",
                "crontab -e",
                "crontab -r",
                "dd .*",
                "docker exec --privileged .*",
                "docker run --privileged .*",
                "fdisk .*",
                "git add.*",
                "git commit.*",
                "init .*",
                "kill -9 .*",
                "killall .*",
                "kubectl apply .*",
                "kubectl create .*",
                "kubectl delete .*",
                "kubectl patch .*",
                "kubectl replace .*",
                "mkfs .*",
                "mount .*",
                "mv /.*",
                "pkill .*",
                "reboot",
                "rm .*",
                "rmdir .*",
                "service .*",
                "shutdown .*",
                "sudo .*",
                "systemctl .*",
                "trash .*",
                "umount .*"
            ]
        },
        "aws": {
            "allowedServices": ["s3", "lambda", "ec2", "ecs", "eks", "cloudformation", "cloudwatch", "logs", "iam", "sts", "ssm"],
            "autoAllowReadonly": true
        },
        "write": {
            "allowedPaths": [
                "~/projects/**",
                "~/repositories/**",
                "~/.dotfiles/**",
                "./**"
            ],
            "deniedPaths": [
                "/etc/**",
                "/usr/**",
                "/bin/**",
                "/sbin/**",
                "/System/**"
            ]
        },
        "grep": {
            "allowedPaths": ["~/projects/**", "~/repositories/**", "~/.dotfiles/**", "./**"],
            "deniedPaths": ["/etc/**", "/usr/**", "/bin/**", "/sbin/**", "/System/**", "**/.env", "**/.env.*"]
        },
        "glob": {
            "allowedPaths": ["~/projects/**", "~/repositories/**", "~/.dotfiles/**", "./**"],
            "deniedPaths": ["/etc/**", "/usr/**", "/bin/**", "/sbin/**", "/System/**", "**/.env", "**/.env.*"]
        },
        "subagent": {
            "availableAgents": ["default", "github", "jira"],
            "trustedAgents": ["default"]
        },
        "web_fetch": {
            "trusted": [
                ".*docs\\.aws\\.amazon\\.com.*",
                ".*github\\.com.*",
                ".*stackoverflow\\.com.*",
                ".*developer\\.mozilla\\.org.*"
            ],
            "blocked": [
                ".*pastebin\\.com.*"
            ]
        }
    }
}
