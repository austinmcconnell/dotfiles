{
    "allowedTools": [
        "@engram/mem_capture_passive",
        "@engram/mem_compare",
        "@engram/mem_context",
        "@engram/mem_current_project",
        "@engram/mem_delete",
        "@engram/mem_doctor",
        "@engram/mem_get_observation",
        "@engram/mem_judge",
        "@engram/mem_save",
        "@engram/mem_save_prompt",
        "@engram/mem_search",
        "@engram/mem_session_end",
        "@engram/mem_session_start",
        "@engram/mem_session_summary",
        "@engram/mem_stats",
        "@engram/mem_suggest_topic_key",
        "@engram/mem_timeline",
        "@engram/mem_update",
        "code",
        "glob",
        "grep",
        "introspect",
        "knowledge",
        "read",
        "subagent",
        "todo",
        "web_fetch",
        "web_search"
    ],
    "description": "Default CLI agent with comprehensive development tools and security restrictions",
    "hooks": {
        "agentSpawn": [
            {
                "command": "~/.dotfiles/etc/kiro-cli/hooks/check-research-kb.sh default",
                "timeout_ms": 5000
            },
            {
                "command": "~/.dotfiles/etc/kiro-cli/hooks/recall-memory.sh",
                "timeout_ms": 5000
            },
            {
                "command": "~/.dotfiles/etc/kiro-cli/hooks/rotate-traces.sh",
                "timeout_ms": 5000
            }
        ],
        "preToolUse": [
            {
                "matcher": "*",
                "command": "~/.dotfiles/etc/ai/hooks/block-env-files.sh",
                "timeout_ms": 5000
            },
            {
                "matcher": "*",
                "command": "~/.dotfiles/etc/ai/hooks/block-sops-age-files.sh",
                "timeout_ms": 5000
            },
            {
                "matcher": "*",
                "command": "~/.dotfiles/etc/ai/hooks/block-ssh-private-keys.sh",
                "timeout_ms": 5000
            },
            {
                "matcher": "use_aws",
                "command": "jq -c '{timestamp: now | strftime(\"%Y-%m-%d %H:%M:%S\"), tool: .tool_name, input: .tool_input}' >> ~/.kiro/logs/aws-audit.jsonl",
                "timeout_ms": 5000
            },
            {
                "matcher": "@kubernetes",
                "command": "jq -c '{timestamp: now | strftime(\"%Y-%m-%d %H:%M:%S\"), tool: .tool_name, input: .tool_input}' >> ~/.kiro/logs/kubectl-audit.jsonl",
                "timeout_ms": 5000
            },
            {
                "matcher": "execute_bash",
                "command": "AI_AGENT_NAME=kiro-cli ~/.dotfiles/etc/ai/hooks/audit-shell-commands.sh",
                "timeout_ms": 5000
            },
            {
                "matcher": "@engram",
                "command": "~/.dotfiles/etc/ai/hooks/block-memory-secrets.sh",
                "timeout_ms": 5000
            }
        ],
        "postToolUse": [
            {
                "matcher": "knowledge",
                "command": "~/.dotfiles/etc/kiro-cli/hooks/clear-research-kb-stale.sh default",
                "timeout_ms": 5000
            },
            {
                "matcher": "*",
                "command": "~/.dotfiles/etc/kiro-cli/hooks/trace-tool-call.sh default",
                "timeout_ms": 3000
            }
        ]
    },
    "includeMcpJson": true,
    "mcpServers": {
        "kubernetes": {
            "args": [
                "-y",
                "kubernetes-mcp-server@latest",
                "--read-only",
                "--toolsets",
                "core,config,helm"
            ],
            "command": "npx",
            "disabled": true,
            "env": {},
            "timeout": 120000
        }
    },
    "name": "default",
    "prompt": "file://./default-prompt.md",
    "resources": [
        "file://AGENTS.md",
        "file://~/.dotfiles/etc/ai/steering/code/**/*.md",
        "file://~/.dotfiles/etc/ai/steering/github/**/*.md",
        "file://~/.dotfiles/etc/ai/steering/security/**/*.md",
        "file://.kiro/steering/**/*.md",
        "file://README.md",
        "skill://.kiro/skills/development/**/SKILL.md",
        "skill://.kiro/skills/operations/**/SKILL.md",
        "skill://.kiro/skills/shared/**/SKILL.md",
        "skill://~/.kiro/skills/development/**/SKILL.md",
        "skill://~/.kiro/skills/operations/**/SKILL.md",
        "skill://~/.kiro/skills/research/**/SKILL.md",
        "skill://~/.kiro/skills/shared/**/SKILL.md",
        {
            "type": "knowledgeBase",
            "source": "file://~/projects/austinmcconnell/_research_",
            "name": "research",
            "description": "Structured research files covering product evaluations, technology comparisons, and technical investigations with cited sources and verification dates",
            "indexType": "best",
            "include": [
                "**/*.md"
            ],
            "exclude": [
                ".git/**"
            ],
            "autoUpdate": false
        },
        {
            "type": "knowledgeBase",
            "source": "file://~/projects/unite-us/screenings-ingestion",
            "name": "screenings-ingestion",
            "description": "Python app code, tests, Terraform infrastructure, and analysis docs for the FHIR screenings ingestion service",
            "indexType": "fast",
            "include": [
                "app/**/*.py",
                "tests/**/*.py",
                "infrastructure/**/*.tf",
                "infrastructure/**/*.yaml",
                "infrastructure/**/*.yml",
                "docs/**/*.md",
                "fhir-analysis/**/*.md",
                "analysis/**/*.md",
                "README.md"
            ],
            "exclude": [
                ".git/**",
                "**/__pycache__/**",
                ".terraform/**",
                ".pre/**",
                ".venv/**",
                "node_modules/**"
            ],
            "autoUpdate": true
        },
        {
            "type": "knowledgeBase",
            "source": "file://~/projects/unite-us/screenings-ingestion/docs",
            "name": "screenings-ingestion-docs",
            "description": "Markdown documentation for the screenings ingestion service including architecture, data flows, and operational guides",
            "indexType": "best",
            "include": [
                "**/*.md"
            ],
            "exclude": [
                ".git/**"
            ],
            "autoUpdate": true
        },
        {
            "type": "knowledgeBase",
            "source": "file://~/projects/unite-us",
            "name": "analysis-all-projects",
            "description": "Cross-project analysis documents covering architecture decisions, research findings, and technical comparisons across all Unite Us projects",
            "indexType": "best",
            "include": [
                "*/analysis/*.md"
            ],
            "exclude": [
                ".git/**"
            ],
            "autoUpdate": false
        },
        {
            "type": "knowledgeBase",
            "source": "file://~/projects/austinmcconnell",
            "name": "analysis-personal-projects",
            "description": "Cross-project analysis documents covering architecture decisions, research findings, and technical comparisons across personal projects",
            "indexType": "best",
            "include": [
                "*/analysis/*.md"
            ],
            "exclude": [
                ".git/**"
            ],
            "autoUpdate": false
        }
    ],
    "tools": [
        "*"
    ],
    "toolsSettings": {
        "shell": {
            "allowedCommands": [
                "awk .*",
                "cat .*",
                "chmod \\+x .*",
                "command -v .*",
                "dirname .*",
                "echo( .*)?",
                "find .*",
                "gh api .*",
                "gh issue list.*",
                "gh issue view.*",
                "gh pr list.*",
                "gh pr view.*",
                "gh run .*",
                "git branch.*",
                "git check-ignore.*",
                "git diff.*",
                "(GIT_PAGER=cat )?git log.*",
                "git ls-files.*",
                "git ls-tree .*",
                "git merge-base .*",
                "git rev-list .*",
                "git rev-parse .*",
                "git show.*",
                "git status.*",
                "grep .*",
                "head .*",
                "hostname",
                "jq( .*)?",
                "ls( .*)?",
                "man .*",
                "mkdir -p .*",
                "pre-commit run .*",
                "pwd",
                "pylint .*",
                "read( .*)?",
                "readlink( .*)?",
                "sed .*",
                "sort( .*)?",
                "source .*",
                "tr .*",
                "tail .*",
                "tree( .*)?",
                "true",
                "type .*",
                "uniq .*",
                "wc .*",
                "which .*",
                "whoami",
                "xargs .*"
            ],
            "deniedCommands": [
                "awk .*\\.env.*",
                "cat .*\\.env.*",
                "grep .*\\.env.*",
                "head .*\\.env.*",
                "sed .*\\.env.*",
                "tail .*\\.env.*",
                "find .*\\.env.*",
                "cat .*sops/age/keys\\.txt.*",
                "cat .*\\.agekey.*",
                "sops (decrypt|--decrypt|-d ).*",
                "cat .*\\.ssh/id_rsa.*",
                "cat .*\\.ssh/id_ed25519.*",
                "cat .*\\.ssh/id_ecdsa.*",
                "cat .*\\.ssh/id_dsa.*",
                "cat .*\\.ssh/.*_key[^.].*",
                "gh auth .*",
                "gh issue close .*",
                "gh issue delete .*",
                "gh label create .*",
                "gh label delete .*",
                "gh label edit .*",
                "gh pr close .*",
                "gh pr merge .*",
                "gh release create .*",
                "gh release delete .*",
                "gh repo create .*",
                "gh repo delete.*",
                "gh repo edit .*",
                "gh repo fork .*",
                "gh run cancel .*",
                "gh run rerun .*",
                "gh secret .*",
                "gh variable .*",
                "gh workflow disable .*",
                "gh workflow run .*",
                "git add \\.",
                "git add -A.*",
                "git add --all.*",
                "chmod [0-7]{3,4} .*",
                "chmod -R .*",
                "chmod u\\+s .*",
                "chmod g\\+s .*",
                "chown .*",
                "cp /.*",
                "crontab -e",
                "crontab -r",
                "dd .*",
                "docker exec --privileged .*",
                "docker run --privileged .*",
                "fdisk .*",
                "init .*",
                "kill -9 .*",
                "killall .*",
                "kubectl apply .*",
                "kubectl create .*",
                "kubectl delete .*",
                "kubectl patch .*",
                "kubectl replace .*",
                "mkfs .*",
                "mount .*",
                "mv /.*",
                "pkill .*",
                "reboot",
                "rm .*",
                "rmdir .*",
                "service .*",
                "shutdown .*",
                "sudo .*",
                "systemctl .*",
                "trash .*",
                "umount .*"
            ]
        },
        "aws": {
            "allowedServices": [
                "s3",
                "lambda",
                "ec2",
                "ecs",
                "eks",
                "cloudformation",
                "cloudwatch",
                "logs",
                "iam",
                "sts",
                "ssm"
            ],
            "autoAllowReadonly": true
        },
        "write": {
            "allowedPaths": [
                "~/projects/**",
                "~/repositories/**",
                "~/.dotfiles/**",
                "./**"
            ],
            "deniedPaths": [
                "/etc/**",
                "/usr/**",
                "/bin/**",
                "/sbin/**",
                "/System/**"
            ]
        },
        "grep": {
            "allowedPaths": [
                "~/projects/**",
                "~/repositories/**",
                "~/.dotfiles/**",
                "./**"
            ],
            "deniedPaths": [
                "/etc/**",
                "/usr/**",
                "/bin/**",
                "/sbin/**",
                "/System/**",
                "**/.env",
                "**/.env.*",
                "**/sops/age/keys.txt",
                "**/*.agekey",
                "**/.ssh/id_rsa",
                "**/.ssh/id_ed25519",
                "**/.ssh/id_ecdsa",
                "**/.ssh/id_dsa",
                "**/.ssh/*_key"
            ]
        },
        "glob": {
            "allowedPaths": [
                "~/projects/**",
                "~/repositories/**",
                "~/.dotfiles/**",
                "./**"
            ],
            "deniedPaths": [
                "/etc/**",
                "/usr/**",
                "/bin/**",
                "/sbin/**",
                "/System/**",
                "**/.env",
                "**/.env.*",
                "**/sops/age/keys.txt",
                "**/*.agekey",
                "**/.ssh/id_rsa",
                "**/.ssh/id_ed25519",
                "**/.ssh/id_ecdsa",
                "**/.ssh/id_dsa",
                "**/.ssh/*_key"
            ]
        },
        "subagent": {
            "availableAgents": [
                "default",
                "docs",
                "jira",
                "ansible"
            ],
            "trustedAgents": [
                "default"
            ]
        },
        "web_fetch": {
            "trusted": [
                ".*docs\\.aws\\.amazon\\.com.*",
                ".*docs\\.github\\.com.*",
                ".*github\\.com.*",
                ".*raw\\.githubusercontent\\.com.*",
                ".*stackoverflow\\.com.*",
                ".*developer\\.mozilla\\.org.*"
            ],
            "blocked": [
                ".*pastebin\\.com.*"
            ]
        },
        "read": {
            "deniedPaths": [
                "**/.env",
                "**/.env.*",
                "**/*.key",
                "**/*.pem",
                "**/credentials*",
                "**/sops/age/keys.txt",
                "**/*.agekey",
                "**/.ssh/id_rsa",
                "**/.ssh/id_ed25519",
                "**/.ssh/id_ecdsa",
                "**/.ssh/id_dsa",
                "**/.ssh/*_key"
            ]
        }
    }
}
