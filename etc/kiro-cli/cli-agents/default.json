{
    "allowedTools": [
        "@git/git_branch",
        "@git/git_diff",
        "@git/git_diff_staged",
        "@git/git_diff_unstaged",
        "@git/git_log",
        "@git/git_show",
        "@git/git_status",
        "code",
        "glob",
        "grep",
        "introspect",
        "knowledge",
        "read",
        "subagent",
        "todo",
        "web_fetch",
        "web_search"
    ],
    "description": "Default CLI agent with comprehensive development tools and security restrictions",
    "hooks": {
        "agentSpawn": [
            {
                "command": "git status --short --branch 2>/dev/null || echo 'Not a git repository'"
            }
        ],
        "preToolUse": [
            {
                "matcher": "*",
                "command": "~/.dotfiles/etc/kiro-cli/hooks/block-env-files.sh"
            },
            {
                "matcher": "use_aws",
                "command": "jq -c '{timestamp: now | strftime(\"%Y-%m-%d %H:%M:%S\"), tool: .tool_name, input: .tool_input}' >> ~/.kiro/logs/aws-audit.jsonl"
            },
            {
                "matcher": "@kubernetes",
                "command": "jq -c '{timestamp: now | strftime(\"%Y-%m-%d %H:%M:%S\"), tool: .tool_name, input: .tool_input}' >> ~/.kiro/logs/kubectl-audit.jsonl"
            },
            {
                "matcher": "execute_bash",
                "command": "~/.dotfiles/etc/kiro-cli/hooks/audit-shell-commands.sh"
            }
        ]
    },
    "includeMcpJson": true,
    "mcpServers": {
        "kubernetes": {
            "args": [
                "-y",
                "kubernetes-mcp-server@latest",
                "--read-only",
                "--toolsets",
                "core,config,helm"
            ],
            "command": "npx",
            "disabled": true,
            "env": {},
            "timeout": 120000
        }
    },
    "name": "default",
    "prompt": "file://./default-prompt.md",
    "resources": [
        "file://AGENTS.md",
        "file://~/.dotfiles/etc/kiro-cli/steering/code/**/*.md",
        "file://~/.dotfiles/etc/kiro-cli/steering/security/**/*.md",
        "file://.kiro/steering/**/*.md",
        "file://README.md",
        "skill://.kiro/skills/development/**/SKILL.md",
        "skill://.kiro/skills/operations/**/SKILL.md",
        "skill://.kiro/skills/shared/**/SKILL.md",
        "skill://~/.kiro/skills/development/**/SKILL.md",
        "skill://~/.kiro/skills/operations/**/SKILL.md",
        "skill://~/.kiro/skills/research/**/SKILL.md",
        "skill://~/.kiro/skills/shared/**/SKILL.md",
        {
            "type": "knowledgeBase",
            "source": "file://~/projects/austinmcconnell/_research_",
            "name": "research",
            "description": "Structured research files covering product evaluations, technology comparisons, and technical investigations with cited sources and verification dates",
            "indexType": "best",
            "include": ["**/*.md"],
            "exclude": [".git/**"],
            "autoUpdate": true
        },
        {
            "type": "knowledgeBase",
            "source": "file://~/projects/unite-us/screenings-ingestion",
            "name": "screenings-ingestion",
            "description": "Python app code, tests, Terraform infrastructure, and analysis docs for the FHIR screenings ingestion service",
            "indexType": "fast",
            "include": [
                "app/**/*.py",
                "tests/**/*.py",
                "infrastructure/**/*.tf",
                "infrastructure/**/*.yaml",
                "infrastructure/**/*.yml",
                "docs/**/*.md",
                "fhir-analysis/**/*.md",
                "analysis/**/*.md",
                "README.md"
            ],
            "exclude": [
                ".git/**",
                "**/__pycache__/**",
                ".terraform/**",
                ".pre/**",
                ".venv/**",
                "node_modules/**"
            ],
            "autoUpdate": true
        },
        {
            "type": "knowledgeBase",
            "source": "file://~/projects/unite-us/screenings-ingestion/docs",
            "name": "screenings-ingestion-docs",
            "description": "Markdown documentation for the screenings ingestion service including architecture, data flows, and operational guides",
            "indexType": "best",
            "include": ["**/*.md"],
            "exclude": [".git/**"],
            "autoUpdate": true
        },
        {
            "type": "knowledgeBase",
            "source": "file://~/projects/unite-us",
            "name": "analysis-all-projects",
            "description": "Cross-project analysis documents covering architecture decisions, research findings, and technical comparisons across all Unite Us projects",
            "indexType": "best",
            "include": ["*/analysis/*.md"],
            "exclude": [".git/**"],
            "autoUpdate": false
        },
        {
            "type": "knowledgeBase",
            "source": "file://~/projects/austinmcconnell",
            "name": "analysis-personal-projects",
            "description": "Cross-project analysis documents covering architecture decisions, research findings, and technical comparisons across personal projects",
            "indexType": "best",
            "include": ["*/analysis/*.md"],
            "exclude": [".git/**"],
            "autoUpdate": false
        }
    ],
    "tools": ["*"],
    "toolsSettings": {
        "shell": {
            "allowedCommands": [
                "awk .*",
                "cat .*",
                "command -v .*",
                "echo .*",
                "find .*",
                "git branch.*",
                "git diff.*",
                "(GIT_PAGER=cat )?git log.*",
                "git merge-base .*",
                "git rev-list .*",
                "git show.*",
                "git status.*",
                "grep .*",
                "head .*",
                "hostname",
                "ls( .*)?",
                "man .*",
                "pwd",
                "readlink .*",
                "sed .*",
                "sort .*",
                "tail .*",
                "tree( .*)?",
                "type .*",
                "uniq .*",
                "wc .*",
                "which .*",
                "whoami"
            ],
            "deniedCommands": [
                "awk .*\\.env.*",
                "cat .*\\.env.*",
                "grep .*\\.env.*",
                "head .*\\.env.*",
                "sed .*\\.env.*",
                "tail .*\\.env.*",
                "find .*\\.env.*",
                "chmod .*",
                "chown .*",
                "cp /.*",
                "crontab -e",
                "crontab -r",
                "dd .*",
                "docker exec --privileged .*",
                "docker run --privileged .*",
                "fdisk .*",
                "git add.*",
                "git commit.*",
                "init .*",
                "kill -9 .*",
                "killall .*",
                "kubectl apply .*",
                "kubectl create .*",
                "kubectl delete .*",
                "kubectl patch .*",
                "kubectl replace .*",
                "mkfs .*",
                "mount .*",
                "mv /.*",
                "pkill .*",
                "reboot",
                "rm .*",
                "rmdir .*",
                "service .*",
                "shutdown .*",
                "sudo .*",
                "systemctl .*",
                "trash .*",
                "umount .*"
            ]
        },
        "aws": {
            "allowedServices": [
                "s3",
                "lambda",
                "ec2",
                "ecs",
                "eks",
                "cloudformation",
                "cloudwatch",
                "logs",
                "iam",
                "sts",
                "ssm"
            ],
            "autoAllowReadonly": true
        },
        "write": {
            "allowedPaths": ["~/projects/**", "~/repositories/**", "~/.dotfiles/**", "./**"],
            "deniedPaths": ["/etc/**", "/usr/**", "/bin/**", "/sbin/**", "/System/**"]
        },
        "grep": {
            "allowedPaths": ["~/projects/**", "~/repositories/**", "~/.dotfiles/**", "./**"],
            "deniedPaths": [
                "/etc/**",
                "/usr/**",
                "/bin/**",
                "/sbin/**",
                "/System/**",
                "**/.env",
                "**/.env.*"
            ]
        },
        "glob": {
            "allowedPaths": ["~/projects/**", "~/repositories/**", "~/.dotfiles/**", "./**"],
            "deniedPaths": [
                "/etc/**",
                "/usr/**",
                "/bin/**",
                "/sbin/**",
                "/System/**",
                "**/.env",
                "**/.env.*"
            ]
        },
        "subagent": {
            "availableAgents": ["default", "github", "jira"],
            "trustedAgents": ["default"]
        },
        "web_fetch": {
            "trusted": [
                ".*docs\\.aws\\.amazon\\.com.*",
                ".*github\\.com.*",
                ".*stackoverflow\\.com.*",
                ".*developer\\.mozilla\\.org.*"
            ],
            "blocked": [".*pastebin\\.com.*"]
        }
    }
}
