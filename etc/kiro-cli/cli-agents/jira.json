{
    "allowedTools": [
        "@engram/mem_capture_passive",
        "@engram/mem_compare",
        "@engram/mem_context",
        "@engram/mem_current_project",
        "@engram/mem_delete",
        "@engram/mem_doctor",
        "@engram/mem_get_observation",
        "@engram/mem_judge",
        "@engram/mem_save",
        "@engram/mem_save_prompt",
        "@engram/mem_search",
        "@engram/mem_session_end",
        "@engram/mem_session_start",
        "@engram/mem_session_summary",
        "@engram/mem_stats",
        "@engram/mem_suggest_topic_key",
        "@engram/mem_timeline",
        "@engram/mem_update",
        "@jira/jira_get",
        "code",
        "glob",
        "grep",
        "introspect",
        "knowledge",
        "read",
        "subagent",
        "todo",
        "web_fetch",
        "web_search"
    ],
    "description": "JIRA-focused agent with deep SCRUM and Agile knowledge, restricted to safe operations",
    "hooks": {
        "agentSpawn": [
            {
                "command": "~/.dotfiles/etc/kiro-cli/hooks/recall-memory.sh",
                "timeout_ms": 5000
            }
        ],
        "preToolUse": [
            {
                "matcher": "*",
                "command": "~/.dotfiles/etc/ai/hooks/block-env-files.sh",
                "timeout_ms": 5000
            },
            {
                "matcher": "*",
                "command": "~/.dotfiles/etc/ai/hooks/block-sops-age-files.sh",
                "timeout_ms": 5000
            },
            {
                "matcher": "*",
                "command": "~/.dotfiles/etc/ai/hooks/block-ssh-private-keys.sh",
                "timeout_ms": 5000
            },
            {
                "matcher": "@engram",
                "command": "~/.dotfiles/etc/ai/hooks/block-memory-secrets.sh",
                "timeout_ms": 5000
            }
        ],
        "userPromptSubmit": []
    },
    "includeMcpJson": true,
    "mcpServers": {
        "jira": {
            "args": [
                "-y",
                "@aashari/mcp-server-atlassian-jira@3.3.0"
            ],
            "command": "npx",
            "disabled": false,
            "disabledTools": [
                "jira_delete"
            ],
            "env": {},
            "timeout": 120000
        }
    },
    "name": "jira",
    "prompt": "file://./jira-prompt.md",
    "resources": [
        "file://AGENTS.md",
        "file://~/.dotfiles/etc/ai/steering/scrum/**/*.md",
        "file://~/.dotfiles/etc/ai/steering/security/env-file-protection.md",
        "file://.kiro/steering/**/*.md",
        "file://README.md",
        "skill://.kiro/skills/**/SKILL.md",
        "skill://~/.kiro/skills/development/**/SKILL.md",
        "skill://~/.kiro/skills/scrum/**/SKILL.md",
        "skill://~/.kiro/skills/shared/**/SKILL.md"
    ],
    "tools": [
        "*"
    ],
    "toolsSettings": {
        "aws": {
            "allowedServices": []
        },
        "shell": {
            "allowedCommands": [
                "awk .*",
                "cat .*",
                "chmod \\+x .*",
                "command -v .*",
                "dirname .*",
                "echo( .*)?",
                "find .*",
                "git branch.*",
                "git check-ignore.*",
                "git diff.*",
                "(GIT_PAGER=cat )?git log.*",
                "git ls-files.*",
                "git ls-tree .*",
                "git merge-base .*",
                "git rev-list .*",
                "git rev-parse .*",
                "git show.*",
                "git status.*",
                "grep .*",
                "head .*",
                "hostname",
                "jq( .*)?",
                "ls( .*)?",
                "man .*",
                "mkdir -p .*",
                "pwd",
                "read( .*)?",
                "readlink( .*)?",
                "sed .*",
                "sort( .*)?",
                "source .*",
                "tail .*",
                "tr .*",
                "tree( .*)?",
                "true",
                "type .*",
                "uniq .*",
                "wc .*",
                "which .*",
                "whoami",
                "xargs .*"
            ],
            "deniedCommands": [
                "awk .*\\.env.*",
                "cat .*\\.env.*",
                "grep .*\\.env.*",
                "head .*\\.env.*",
                "sed .*\\.env.*",
                "tail .*\\.env.*",
                "cat .*sops/age/keys\\.txt.*",
                "cat .*\\.agekey.*",
                "sops (decrypt|--decrypt|-d ).*",
                "cat .*\\.ssh/id_rsa.*",
                "cat .*\\.ssh/id_ed25519.*",
                "cat .*\\.ssh/id_ecdsa.*",
                "cat .*\\.ssh/id_dsa.*",
                "cat .*\\.ssh/.*_key[^.].*",
                "aws .*",
                "brew install .*",
                "chmod [0-7]{3,4} .*",
                "chmod -R .*",
                "chmod u\\+s .*",
                "chmod g\\+s .*",
                "chown .*",
                "cp .*",
                "crontab .*",
                "dd .*",
                "docker .*",
                "git add \\.",
                "git add -A.*",
                "git add --all.*",
                "git merge .*",
                "git push .*",
                "git rebase .*",
                "kill .*",
                "killall .*",
                "kubectl .*",
                "mv .*",
                "npm install .*",
                "pip install .*",
                "pkill .*",
                "rm .*",
                "rmdir .*",
                "service .*",
                "sudo .*",
                "systemctl .*",
                "trash .*"
            ]
        },
        "write": {
            "allowedPaths": [
                "~/projects/**",
                "~/repositories/**",
                "~/.dotfiles/**",
                "./**"
            ],
            "deniedPaths": [
                "/etc/**",
                "/usr/**",
                "/bin/**",
                "/sbin/**",
                "/System/**"
            ]
        },
        "grep": {
            "allowedPaths": [
                "~/projects/**",
                "~/repositories/**",
                "~/.dotfiles/**",
                "./**"
            ],
            "deniedPaths": [
                "/etc/**",
                "/usr/**",
                "/bin/**",
                "/sbin/**",
                "/System/**",
                "**/.env",
                "**/.env.*",
                "**/sops/age/keys.txt",
                "**/*.agekey",
                "**/.ssh/id_rsa",
                "**/.ssh/id_ed25519",
                "**/.ssh/id_ecdsa",
                "**/.ssh/id_dsa",
                "**/.ssh/*_key"
            ]
        },
        "glob": {
            "allowedPaths": [
                "~/projects/**",
                "~/repositories/**",
                "~/.dotfiles/**",
                "./**"
            ],
            "deniedPaths": [
                "/etc/**",
                "/usr/**",
                "/bin/**",
                "/sbin/**",
                "/System/**",
                "**/.env",
                "**/.env.*",
                "**/sops/age/keys.txt",
                "**/*.agekey",
                "**/.ssh/id_rsa",
                "**/.ssh/id_ed25519",
                "**/.ssh/id_ecdsa",
                "**/.ssh/id_dsa",
                "**/.ssh/*_key"
            ]
        },
        "subagent": {
            "availableAgents": [
                "default",
                "docs",
                "jira",
                "ansible"
            ],
            "trustedAgents": [
                "default"
            ]
        },
        "web_fetch": {
            "trusted": [
                ".*atlassian\\.com.*",
                ".*atlassian\\.net.*"
            ],
            "blocked": [
                ".*pastebin\\.com.*"
            ]
        },
        "read": {
            "deniedPaths": [
                "**/.env",
                "**/.env.*",
                "**/*.key",
                "**/*.pem",
                "**/credentials*",
                "**/sops/age/keys.txt",
                "**/*.agekey",
                "**/.ssh/id_rsa",
                "**/.ssh/id_ed25519",
                "**/.ssh/id_ecdsa",
                "**/.ssh/id_dsa",
                "**/.ssh/*_key"
            ]
        }
    }
}
