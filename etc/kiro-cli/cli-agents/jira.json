{
    "allowedTools": [
        "@jira/jira_get",
        "code",
        "glob",
        "grep",
        "introspect",
        "knowledge",
        "read",
        "subagent",
        "todo",
        "web_fetch",
        "web_search"
    ],
    "description": "JIRA-focused agent with deep SCRUM and Agile knowledge, restricted to safe operations",
    "hooks": {
        "agentSpawn": [],
        "preToolUse": [
            {
                "matcher": "*",
                "command": "~/.dotfiles/etc/ai/hooks/block-env-files.sh"
            }
        ],
        "userPromptSubmit": []
    },
    "includeMcpJson": true,
    "mcpServers": {
        "jira": {
            "args": [
                "-y",
                "@aashari/mcp-server-atlassian-jira"
            ],
            "command": "npx",
            "disabled": false,
            "disabledTools": ["jira_delete"],
            "env": {},
            "timeout": 120000
        }
    },
    "name": "jira",
    "prompt": "file://./jira-prompt.md",
    "resources": [
        "file://AGENTS.md",
        "file://~/.dotfiles/etc/ai/steering/scrum/**/*.md",
        "file://~/.dotfiles/etc/ai/steering/security/env-file-protection.md",
        "file://.kiro/steering/**/*.md",
        "file://README.md",
        "skill://.kiro/skills/**/SKILL.md",
        "skill://~/.kiro/skills/development/**/SKILL.md",
        "skill://~/.kiro/skills/scrum/**/SKILL.md",
        "skill://~/.kiro/skills/shared/**/SKILL.md"
    ],
    "tools": [
        "*"
    ],
    "toolsSettings": {
        "aws": {
            "allowedServices": []
        },
        "shell": {
            "allowedCommands": [
                "awk .*",
                "cat .*",
                "chmod \\+x .*",
                "command -v .*",
                "dirname .*",
                "echo( .*)?",
                "find .*",
                "git branch.*",
                "git check-ignore.*",
                "git diff.*",
                "(GIT_PAGER=cat )?git log.*",
                "git ls-files.*",
                "git ls-tree .*",
                "git merge-base .*",
                "git rev-list .*",
                "git rev-parse .*",
                "git show.*",
                "git status.*",
                "grep .*",
                "head .*",
                "hostname",
                "jq( .*)?",
                "ls( .*)?",
                "man .*",
                "mkdir -p .*",
                "pwd",
                "read( .*)?",
                "readlink( .*)?",
                "sed .*",
                "sort( .*)?",
                "tail .*",
                "tr .*",
                "tree( .*)?",
                "true",
                "type .*",
                "uniq .*",
                "wc .*",
                "which .*",
                "whoami",
                "xargs .*"
            ],
            "deniedCommands": [
                "awk .*\\.env.*",
                "cat .*\\.env.*",
                "grep .*\\.env.*",
                "head .*\\.env.*",
                "sed .*\\.env.*",
                "tail .*\\.env.*",
                "aws .*",
                "brew install .*",
                "chmod [0-7]{3,4} .*",
                "chmod -R .*",
                "chmod u\\+s .*",
                "chmod g\\+s .*",
                "chown .*",
                "cp .*",
                "crontab .*",
                "dd .*",
                "docker .*",
                "git add \\.",
                "git add -A.*",
                "git add --all.*",
                "git merge .*",
                "git push .*",
                "git rebase .*",
                "kill .*",
                "killall .*",
                "kubectl .*",
                "mv .*",
                "npm install .*",
                "pip install .*",
                "pkill .*",
                "rm .*",
                "rmdir .*",
                "service .*",
                "sudo .*",
                "systemctl .*",
                "trash .*"
            ]
        },
        "write": {
            "allowedPaths": [
                "~/projects/**",
                "~/repositories/**",
                "~/.dotfiles/**",
                "./**"
            ],
            "deniedPaths": [
                "/etc/**",
                "/usr/**",
                "/bin/**",
                "/sbin/**",
                "/System/**"
            ]
        },
        "grep": {
            "allowedPaths": ["~/projects/**", "~/repositories/**", "~/.dotfiles/**", "./**"],
            "deniedPaths": ["/etc/**", "/usr/**", "/bin/**", "/sbin/**", "/System/**", "**/.env", "**/.env.*"]
        },
        "glob": {
            "allowedPaths": ["~/projects/**", "~/repositories/**", "~/.dotfiles/**", "./**"],
            "deniedPaths": ["/etc/**", "/usr/**", "/bin/**", "/sbin/**", "/System/**", "**/.env", "**/.env.*"]
        },
        "subagent": {
            "availableAgents": ["default", "docs", "jira"],
            "trustedAgents": ["default"]
        },
        "web_fetch": {
            "trusted": [
                ".*atlassian\\.com.*",
                ".*atlassian\\.net.*"
            ],
            "blocked": [
                ".*pastebin\\.com.*"
            ]
        }
    }
}
