{
    "allowedTools": [
        "@time/convert_time",
        "@time/get_current_time",
        "@jira/jira_get_create_meta",
        "@jira/jira_get_issue",
        "@jira/jira_get_project",
        "@jira/jira_ls_comments",
        "@jira/jira_ls_issues",
        "@jira/jira_ls_projects",
        "@jira/jira_ls_statuses",
        "@jira/jira_ls_worklogs",
        "@git/git_branch",
        "@git/git_diff",
        "@git/git_diff_staged",
        "@git/git_diff_unstaged",
        "@git/git_log",
        "@git/git_show",
        "@git/git_status",
        "@filesystem/get_file_info",
        "@filesystem/list_directory_with_sizes",
        "@filesystem/read_media_file",
        "@filesystem/read_multiple_files",
        "@filesystem/read_text_file",
        "@filesystem/search_files",
        "fs_read",
        "glob",
        "grep",
        "use_subagent",
        "web_fetch",
        "web_search"
    ],
    "description": "JIRA-focused agent with deep SCRUM and Agile knowledge, restricted to safe operations",
    "hooks": {
        "agentSpawn": [],
        "userPromptSubmit": []
    },
    "includeMcpJson": true,
    "mcpServers": {
        "jira": {
            "args": [
                "@aashari/mcp-server-atlassian-jira"
            ],
            "command": "npx",
            "disabled": false,
            "env": {},
            "timeout": 120000
        },
        "time": {
            "args": [
                "-m",
                "mcp_server_time",
                "--local-timezone=America/Chicago"
            ],
            "command": "python",
            "disabled": false,
            "env": {},
            "timeout": 30000
        }
    },
    "name": "jira",
    "prompt": "file://./jira-prompt.md",
    "resources": [
        "file://AGENTS.md",
        "file://~/.dotfiles/etc/kiro-cli/steering/jira-scrum/**/*.md",
        "file://.kiro/steering/**/*.md",
        "file://README.md",
        "skill://.kiro/skills/**/SKILL.md",
        "skill://~/.kiro/skills/**/SKILL.md"
    ],
    "tools": [
        "*"
    ],
    "toolsSettings": {
        "shell": {
            "allowedCommands": [
                "awk .*",
                "cat .*",
                "command -v .*",
                "git branch.*",
                "git diff.*",
                "git log.*",
                "git show.*",
                "git status.*",
                "grep .*",
                "head .*",
                "hostname",
                "ls .*",
                "man .*",
                "pwd",
                "sed .*",
                "sort .*",
                "tail .*",
                "type .*",
                "uniq .*",
                "wc .*",
                "which .*",
                "whoami"
            ],
            "deniedCommands": [
                "aws .*",
                "brew install .*",
                "chmod .*",
                "chown .*",
                "cp .*",
                "crontab .*",
                "dd .*",
                "docker .*",
                "git add.*",
                "git commit .*",
                "git merge .*",
                "git push .*",
                "git rebase .*",
                "kill .*",
                "killall .*",
                "kubectl .*",
                "mv .*",
                "npm install .*",
                "pip install .*",
                "pkill .*",
                "rm .*",
                "rmdir .*",
                "service .*",
                "sudo .*",
                "systemctl .*",
                "trash .*"
            ]
        },
        "write": {
            "allowedPaths": [
                "~/projects/**",
                "~/repositories/**",
                "~/.dotfiles/**",
                "./**"
            ],
            "deniedPaths": [
                "/etc/**",
                "/usr/**",
                "/bin/**",
                "/sbin/**",
                "/System/**"
            ]
        },
        "grep": {
            "allowedPaths": ["~/projects/**", "~/repositories/**", "~/.dotfiles/**", "./**"],
            "deniedPaths": ["/etc/**", "/usr/**", "/bin/**", "/sbin/**", "/System/**"]
        },
        "glob": {
            "allowedPaths": ["~/projects/**", "~/repositories/**", "~/.dotfiles/**", "./**"],
            "deniedPaths": ["/etc/**", "/usr/**", "/bin/**", "/sbin/**", "/System/**"]
        },
        "subagent": {
            "availableAgents": ["default", "github", "jira"],
            "trustedAgents": ["default"]
        },
        "web_fetch": {
            "trustedUrlPatterns": [
                ".*atlassian\\.com.*",
                ".*atlassian\\.net.*"
            ],
            "blockedUrlPatterns": [
                ".*pastebin\\.com.*"
            ]
        }
    }
}
