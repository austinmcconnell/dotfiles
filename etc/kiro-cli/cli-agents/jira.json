{
    "allowedTools": [
        "convert_time",
        "fs_read",
        "get_current_time",
        "get_file_info",
        "git_branch",
        "git_diff",
        "git_diff_staged",
        "git_diff_unstaged",
        "git_log",
        "git_show",
        "git_status",
        "glob",
        "grep",
        "jira_get_create_meta",
        "jira_get_issue",
        "jira_get_project",
        "jira_ls_comments",
        "jira_ls_issues",
        "jira_ls_projects",
        "jira_ls_statuses",
        "jira_ls_worklogs",
        "list_directory_with_sizes",
        "read_media_file",
        "read_multiple_files",
        "read_text_file",
        "search_files",
        "web_fetch",
        "web_search"
    ],
    "description": "JIRA-focused agent with deep SCRUM and Agile knowledge, restricted to safe operations",
    "hooks": {
        "agentSpawn": [],
        "userPromptSubmit": []
    },
    "keyboardShortcut": "ctrl+j",
    "useLegacyMcpJson": true,
    "mcpServers": {
        "jira": {
            "args": [
                "@aashari/mcp-server-atlassian-jira"
            ],
            "command": "npx",
            "disabled": false,
            "env": {},
            "timeout": 120000
        },
        "time": {
            "args": [
                "-m",
                "mcp_server_time",
                "--local-timezone=America/Chicago"
            ],
            "command": "python",
            "disabled": false,
            "env": {},
            "timeout": 30000
        }
    },
    "name": "jira",
    "prompt": "file://./jira-prompt.md",
    "resources": [
        "file://AGENTS.md",
        "file://~/.dotfiles/etc/kiro-cli/steering/jira-scrum/**/*.md",
        "file://.kiro/steering/**/*.md",
        "file://README.md",
        "skill://.kiro/skills/**/SKILL.md",
        "skill://~/.kiro/skills/**/SKILL.md"
    ],
    "tools": [
        "*"
    ],
    "toolsSettings": {
        "shell": {
            "allowedCommands": [
                "awk .*",
                "cat .*",
                "command -v .*",
                "git branch.*",
                "git diff.*",
                "git log.*",
                "git show.*",
                "git status.*",
                "grep .*",
                "head .*",
                "hostname",
                "ls .*",
                "man .*",
                "pwd",
                "sed .*",
                "sort .*",
                "tail .*",
                "type .*",
                "uniq .*",
                "wc .*",
                "which .*",
                "whoami"
            ],
            "deniedCommands": [
                "aws .*",
                "brew install .*",
                "chmod .*",
                "chown .*",
                "cp .*",
                "crontab .*",
                "dd .*",
                "docker .*",
                "git add.*",
                "git commit .*",
                "git merge .*",
                "git push .*",
                "git rebase .*",
                "kill .*",
                "killall .*",
                "kubectl .*",
                "mv .*",
                "npm install .*",
                "pip install .*",
                "pkill .*",
                "rm .*",
                "rmdir .*",
                "service .*",
                "sudo .*",
                "systemctl .*",
                "trash .*"
            ]
        },
        "write": {
            "allowedPaths": [
                "~/projects/**",
                "~/repositories/**",
                "~/.dotfiles/**",
                "./**"
            ],
            "deniedPaths": [
                "/etc/**",
                "/usr/**",
                "/bin/**",
                "/sbin/**",
                "/System/**"
            ]
        },
        "web_fetch": {
            "trustedUrlPatterns": [
                ".*atlassian\\.com.*",
                ".*atlassian\\.net.*"
            ],
            "blockedUrlPatterns": [
                ".*pastebin\\.com.*"
            ]
        }
    }
}
