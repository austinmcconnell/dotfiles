{
    "allowedTools": [
        "@filesystem/create_directory",
        "@filesystem/get_file_info",
        "@filesystem/read_media_file",
        "@filesystem/read_multiple_files",
        "@filesystem/read_text_file",
        "@filesystem/search_files",
        "@git/git_branch",
        "@git/git_diff",
        "@git/git_diff_staged",
        "@git/git_diff_unstaged",
        "@git/git_log",
        "@git/git_show",
        "@git/git_status",
        "@github/get_commit",
        "@github/get_file_contents",
        "@github/get_label",
        "@github/get_latest_release",
        "@github/get_me",
        "@github/get_release_by_tag",
        "@github/get_tag",
        "@github/get_team_members",
        "@github/get_teams",
        "@github/issue_read",
        "@github/list_branches",
        "@github/list_commits",
        "@github/list_issue_types",
        "@github/list_issues",
        "@github/list_pull_requests",
        "@github/list_releases",
        "@github/list_tags",
        "@github/pull_request_read",
        "@github/search_code",
        "@github/search_issues",
        "@github/search_pull_requests",
        "@github/search_repositories",
        "@github/search_users",
        "@time/convert_time",
        "@time/get_current_time",
        "fs_read",
        "glob",
        "grep",
        "use_subagent",
        "web_fetch",
        "web_search"
    ],
    "description": "GitHub-focused agent with comprehensive repository management and security restrictions",
    "hooks": {
        "agentSpawn": [],
        "preToolUse": [
            {
                "matcher": "*",
                "command": "~/.dotfiles/etc/kiro-cli/hooks/block-env-files.sh"
            }
        ],
        "userPromptSubmit": []
    },

    "includeMcpJson": true,
    "mcpServers": {
        "github": {
            "args": [
                "stdio"
            ],
            "command": "github-mcp-server",
            "disabled": false,
            "env": {
                "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PAT}"
            },
            "timeout": 120000
        },
        "time": {
            "args": [
                "mcp-server-time",
                "--local-timezone=America/Chicago"
            ],
            "command": "uvx",
            "disabled": false,
            "env": {},
            "timeout": 30000
        }
    },
    "name": "github",
    "prompt": "file://./github-prompt.md",
    "resources": [
        "file://AGENTS.md",
        "file://~/.dotfiles/etc/kiro-cli/steering/security/env-file-protection.md",
        "file://.kiro/steering/**/*.md",
        "file://README.md",
        "file://docs/**/*.md",
        "skill://.kiro/skills/**/SKILL.md",
        "skill://~/.kiro/skills/development/**/SKILL.md",
        "skill://~/.kiro/skills/shared/**/SKILL.md"
    ],
    "tools": [
        "*"
    ],
    "toolsSettings": {
        "shell": {
            "allowedCommands": [
                "awk .*",
                "cat .*",
                "cd .*",
                "command -v .*",
                "git branch.*",
                "git diff.*",
                "git log.*",
                "git show.*",
                "git status.*",
                "grep .*",
                "head .*",
                "hostname",
                "ls( .*)?",
                "man .*",
                "pwd",
                "sed .*",
                "sort .*",
                "tail .*",
                "type .*",
                "uniq .*",
                "wc .*",
                "which .*",
                "whoami"
            ],
            "deniedCommands": [
                "awk .*\\.env.*",
                "cat .*\\.env.*",
                "grep .*\\.env.*",
                "head .*\\.env.*",
                "sed .*\\.env.*",
                "tail .*\\.env.*",
                "aws .*",
                "chmod .*",
                "chown .*",
                "cp /.*",
                "crontab .*",
                "dd .*",
                "docker exec .*",
                "docker rm .*",
                "docker rmi .*",
                "docker run .*",
                "git add.*",
                "git commit.*",
                "kill .*",
                "killall .*",
                "kubectl .*",
                "mv /.*",
                "pkill .*",
                "rm .*",
                "rmdir .*",
                "service .*",
                "sudo .*",
                "systemctl .*",
                "trash .*"
            ]
        },
        "write": {
            "allowedPaths": [
                "~/projects/**",
                "~/repositories/**",
                "~/.dotfiles/**",
                "./**"
            ],
            "deniedPaths": [
                "/etc/**",
                "/usr/**",
                "/bin/**",
                "/sbin/**",
                "/System/**"
            ]
        },
        "grep": {
            "allowedPaths": ["~/projects/**", "~/repositories/**", "~/.dotfiles/**", "./**"],
            "deniedPaths": ["/etc/**", "/usr/**", "/bin/**", "/sbin/**", "/System/**", "**/.env", "**/.env.*"]
        },
        "glob": {
            "allowedPaths": ["~/projects/**", "~/repositories/**", "~/.dotfiles/**", "./**"],
            "deniedPaths": ["/etc/**", "/usr/**", "/bin/**", "/sbin/**", "/System/**", "**/.env", "**/.env.*"]
        },
        "subagent": {
            "availableAgents": ["default", "github", "jira"],
            "trustedAgents": ["default"]
        },
        "web_fetch": {
            "trusted": [
                ".*github\\.com.*",
                ".*docs\\.github\\.com.*",
                ".*raw\\.githubusercontent\\.com.*"
            ],
            "blocked": [
                ".*pastebin\\.com.*"
            ]
        }
    }
}
