{
    "allowedTools": [
        "@github/get_commit",
        "@github/get_file_contents",
        "@github/get_label",
        "@github/get_latest_release",
        "@github/get_me",
        "@github/get_release_by_tag",
        "@github/get_tag",
        "@github/get_team_members",
        "@github/get_teams",
        "@github/issue_read",
        "@github/list_branches",
        "@github/list_commits",
        "@github/list_issue_types",
        "@github/list_issues",
        "@github/list_pull_requests",
        "@github/list_releases",
        "@github/list_tags",
        "@github/pull_request_read",
        "@github/search_code",
        "@github/search_issues",
        "@github/search_pull_requests",
        "@github/search_repositories",
        "@github/search_users",
        "code",
        "glob",
        "grep",
        "introspect",
        "knowledge",
        "read",
        "subagent",
        "todo",
        "web_fetch",
        "web_search"
    ],
    "description": "GitHub-focused agent with comprehensive repository management and security restrictions",
    "hooks": {
        "agentSpawn": [],
        "preToolUse": [
            {
                "matcher": "*",
                "command": "~/.dotfiles/etc/kiro-cli/hooks/block-env-files.sh"
            }
        ],
        "userPromptSubmit": []
    },

    "includeMcpJson": true,
    "mcpServers": {
        "github": {
            "args": [
                "stdio"
            ],
            "command": "github-mcp-server",
            "disabled": false,
            "env": {
                "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PAT}"
            },
            "timeout": 120000
        }
    },
    "name": "github",
    "prompt": "file://./github-prompt.md",
    "resources": [
        "file://AGENTS.md",
        "file://~/.dotfiles/etc/kiro-cli/steering/github/**/*.md",
        "file://~/.dotfiles/etc/kiro-cli/steering/security/**/*.md",
        "file://.kiro/steering/**/*.md",
        "file://README.md",
        "file://docs/**/*.md",
        "skill://.kiro/skills/**/SKILL.md",
        "skill://~/.kiro/skills/development/**/SKILL.md",
        "skill://~/.kiro/skills/shared/**/SKILL.md"
    ],
    "tools": [
        "*"
    ],
    "toolsSettings": {
        "aws": {
            "allowedServices": []
        },
        "shell": {
            "allowedCommands": [
                "awk .*",
                "cat .*",
                "chmod \\+x .*",
                "command -v .*",
                "echo .*",
                "find .*",
                "gh api .*",
                "gh issue .*",
                "gh pr .*",
                "gh run .*",
                "git branch.*",
                "git diff.*",
                "(GIT_PAGER=cat )?git log.*",
                "git ls-files.*",
                "git ls-tree .*",
                "git merge-base .*",
                "git rev-list .*",
                "git rev-parse .*",
                "git show.*",
                "git status.*",
                "grep .*",
                "head .*",
                "hostname",
                "jq( .*)?",
                "ls( .*)?",
                "man .*",
                "mkdir -p .*",
                "pwd",
                "readlink .*",
                "sed .*",
                "sort( .*)?",
                "tail .*",
                "tr .*",
                "tree( .*)?",
                "type .*",
                "uniq .*",
                "wc .*",
                "which .*",
                "whoami"
            ],
            "deniedCommands": [
                "awk .*\\.env.*",
                "cat .*\\.env.*",
                "grep .*\\.env.*",
                "head .*\\.env.*",
                "sed .*\\.env.*",
                "tail .*\\.env.*",
                "find .*\\.env.*",
                "aws .*",
                "chmod [0-7]{3,4} .*",
                "chmod -R .*",
                "chmod u\\+s .*",
                "chmod g\\+s .*",
                "chown .*",
                "cp /.*",
                "crontab .*",
                "dd .*",
                "docker exec .*",
                "docker rm .*",
                "docker rmi .*",
                "docker run .*",
                "gh auth .*",
                "gh repo delete.*",
                "gh secret .*",
                "gh variable .*",
                "git add \\.",
                "git add -A.*",
                "git add --all.*",
                "kill .*",
                "killall .*",
                "kubectl .*",
                "mv /.*",
                "pkill .*",
                "rm .*",
                "rmdir .*",
                "service .*",
                "sudo .*",
                "systemctl .*",
                "trash .*"
            ]
        },
        "write": {
            "allowedPaths": [
                "~/projects/**",
                "~/repositories/**",
                "~/.dotfiles/**",
                "./**"
            ],
            "deniedPaths": [
                "/etc/**",
                "/usr/**",
                "/bin/**",
                "/sbin/**",
                "/System/**"
            ]
        },
        "grep": {
            "allowedPaths": ["~/projects/**", "~/repositories/**", "~/.dotfiles/**", "./**"],
            "deniedPaths": ["/etc/**", "/usr/**", "/bin/**", "/sbin/**", "/System/**", "**/.env", "**/.env.*"]
        },
        "glob": {
            "allowedPaths": ["~/projects/**", "~/repositories/**", "~/.dotfiles/**", "./**"],
            "deniedPaths": ["/etc/**", "/usr/**", "/bin/**", "/sbin/**", "/System/**", "**/.env", "**/.env.*"]
        },
        "subagent": {
            "availableAgents": ["default", "docs", "github", "jira"],
            "trustedAgents": ["default"]
        },
        "web_fetch": {
            "trusted": [
                ".*github\\.com.*",
                ".*docs\\.github\\.com.*",
                ".*raw\\.githubusercontent\\.com.*"
            ],
            "blocked": [
                ".*pastebin\\.com.*"
            ]
        }
    }
}
