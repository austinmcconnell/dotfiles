{
    "allowedTools": [
        "code",
        "glob",
        "grep",
        "introspect",
        "knowledge",
        "read",
        "subagent",
        "todo",
        "web_fetch",
        "web_search"
    ],
    "description": "GitHub-focused agent with comprehensive repository management and security restrictions",
    "hooks": {
        "agentSpawn": [],
        "preToolUse": [
            {
                "matcher": "*",
                "command": "~/.dotfiles/etc/kiro-cli/hooks/block-env-files.sh"
            }
        ],
        "userPromptSubmit": []
    },

    "includeMcpJson": true,
    "mcpServers": {},
    "name": "github",
    "prompt": "file://./github-prompt.md",
    "resources": [
        "file://AGENTS.md",
        "file://~/.dotfiles/etc/kiro-cli/steering/github/**/*.md",
        "file://~/.dotfiles/etc/kiro-cli/steering/security/**/*.md",
        "file://.kiro/steering/**/*.md",
        "file://README.md",
        "file://docs/**/*.md",
        "skill://.kiro/skills/**/SKILL.md",
        "skill://~/.kiro/skills/development/**/SKILL.md",
        "skill://~/.kiro/skills/shared/**/SKILL.md"
    ],
    "tools": [
        "*"
    ],
    "toolsSettings": {
        "aws": {
            "allowedServices": []
        },
        "shell": {
            "allowedCommands": [
                "awk .*",
                "cat .*",
                "chmod \\+x .*",
                "command -v .*",
                "echo .*",
                "find .*",
                "gh api .*",
                "gh issue .*",
                "gh pr .*",
                "gh run .*",
                "git branch.*",
                "git diff.*",
                "(GIT_PAGER=cat )?git log.*",
                "git ls-files.*",
                "git ls-tree .*",
                "git merge-base .*",
                "git rev-list .*",
                "git rev-parse .*",
                "git show.*",
                "git status.*",
                "grep .*",
                "head .*",
                "hostname",
                "jq( .*)?",
                "ls( .*)?",
                "man .*",
                "mkdir -p .*",
                "pwd",
                "readlink .*",
                "sed .*",
                "sort( .*)?",
                "tail .*",
                "tr .*",
                "tree( .*)?",
                "type .*",
                "uniq .*",
                "wc .*",
                "which .*",
                "whoami"
            ],
            "deniedCommands": [
                "awk .*\\.env.*",
                "cat .*\\.env.*",
                "grep .*\\.env.*",
                "head .*\\.env.*",
                "sed .*\\.env.*",
                "tail .*\\.env.*",
                "find .*\\.env.*",
                "aws .*",
                "chmod [0-7]{3,4} .*",
                "chmod -R .*",
                "chmod u\\+s .*",
                "chmod g\\+s .*",
                "chown .*",
                "cp /.*",
                "crontab .*",
                "dd .*",
                "docker exec .*",
                "docker rm .*",
                "docker rmi .*",
                "docker run .*",
                "gh auth .*",
                "gh issue close .*",
                "gh issue delete .*",
                "gh label create .*",
                "gh label delete .*",
                "gh label edit .*",
                "gh pr close .*",
                "gh pr merge .*",
                "gh release create .*",
                "gh release delete .*",
                "gh repo create .*",
                "gh repo delete.*",
                "gh repo edit .*",
                "gh repo fork .*",
                "gh run cancel .*",
                "gh run rerun .*",
                "gh secret .*",
                "gh variable .*",
                "gh workflow disable .*",
                "gh workflow run .*",
                "git add \\.",
                "git add -A.*",
                "git add --all.*",
                "kill .*",
                "killall .*",
                "kubectl .*",
                "mv /.*",
                "pkill .*",
                "rm .*",
                "rmdir .*",
                "service .*",
                "sudo .*",
                "systemctl .*",
                "trash .*"
            ]
        },
        "write": {
            "allowedPaths": [
                "~/projects/**",
                "~/repositories/**",
                "~/.dotfiles/**",
                "./**"
            ],
            "deniedPaths": [
                "/etc/**",
                "/usr/**",
                "/bin/**",
                "/sbin/**",
                "/System/**"
            ]
        },
        "grep": {
            "allowedPaths": ["~/projects/**", "~/repositories/**", "~/.dotfiles/**", "./**"],
            "deniedPaths": ["/etc/**", "/usr/**", "/bin/**", "/sbin/**", "/System/**", "**/.env", "**/.env.*"]
        },
        "glob": {
            "allowedPaths": ["~/projects/**", "~/repositories/**", "~/.dotfiles/**", "./**"],
            "deniedPaths": ["/etc/**", "/usr/**", "/bin/**", "/sbin/**", "/System/**", "**/.env", "**/.env.*"]
        },
        "subagent": {
            "availableAgents": ["default", "docs", "github", "jira"],
            "trustedAgents": ["default"]
        },
        "web_fetch": {
            "trusted": [
                ".*github\\.com.*",
                ".*docs\\.github\\.com.*",
                ".*raw\\.githubusercontent\\.com.*"
            ],
            "blocked": [
                ".*pastebin\\.com.*"
            ]
        }
    }
}
