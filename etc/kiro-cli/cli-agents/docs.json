{
    "name": "docs",
    "description": "Documentation project specialist with mdBook expertise and best practices",
    "prompt": "file://./docs-prompt.md",

    "resources": [
        "file://~/.dotfiles/etc/kiro-cli/steering/documentation/**/*.md",
        "file://~/.dotfiles/etc/kiro-cli/steering/security/env-file-protection.md",
        "file://.kiro/steering/**/*.md",
        "file://AGENTS.md",
        "file://README.md",
        "file://SUMMARY.md",
        "file://book.toml",
        "skill://.kiro/skills/**/SKILL.md",
        "skill://~/.kiro/skills/documentation/**/SKILL.md",
        "skill://~/.kiro/skills/shared/**/SKILL.md",
        {
            "type": "knowledgeBase",
            "source": "file://~/projects/unite-us/sdohcc-screening-observations",
            "name": "sdohcc-screening-observations",
            "description": "SDOHCC screening observations mdBook documentation covering FHIR observation mappings, screening instruments, and clinical data standards",
            "indexType": "best",
            "include": ["**/*.md"],
            "exclude": ["book/**", "scripts/**", "reports/**", ".kiro/**"],
            "autoUpdate": true
        },
        {
            "type": "knowledgeBase",
            "source": "file://~/projects/austinmcconnell/_documentation_/gaming-media-pc",
            "name": "gaming-media-pc-docs",
            "description": "Gaming and media PC build documentation covering component selection, BIOS/Windows configuration, game streaming setup, and architecture decision records",
            "indexType": "best",
            "include": ["**/*.md"],
            "exclude": ["book/**", "scripts/**", "reports/**"],
            "autoUpdate": true
        },
        {
            "type": "knowledgeBase",
            "source": "file://~/projects/austinmcconnell/_documentation_/tiny-lab",
            "name": "tiny-lab-docs",
            "description": "Compact Proxmox homelab cluster documentation covering M920x Tiny hardware, ZFS storage, networking, rack layout, and cluster expansion decisions",
            "indexType": "best",
            "include": ["**/*.md"],
            "exclude": ["book/**", "scripts/**", "reports/**"],
            "autoUpdate": true
        },
        {
            "type": "knowledgeBase",
            "source": "file://~/projects/austinmcconnell/_documentation_/truenas-server",
            "name": "truenas-server-docs",
            "description": "TrueNAS backup server build documentation covering ODROID H4+ hardware, ZFS mirror storage, network configuration, and component selection decisions",
            "indexType": "best",
            "include": ["**/*.md"],
            "exclude": ["book/**", "scripts/**", "reports/**"],
            "autoUpdate": true
        },
        {
            "type": "knowledgeBase",
            "source": "file://~/projects/austinmcconnell/_documentation_/ubiquiti-network-stack",
            "name": "ubiquiti-network-docs",
            "description": "Ubiquiti UniFi home network documentation covering gateway, switches, access points, VLANs, firewall rules, VPN, WiFi, and DNS ad blocking configuration",
            "indexType": "best",
            "include": ["**/*.md"],
            "exclude": ["book/**", "scripts/**", "reports/**"],
            "autoUpdate": true
        }
    ],

    "allowedTools": [
        "@filesystem/create_directory",
        "@filesystem/get_file_info",
        "@filesystem/list_allowed_directories",
        "@filesystem/read_multiple_files",
        "@filesystem/read_text_file",
        "@filesystem/read_file",
        "@filesystem/search_files",
        "@git/git_branch",
        "@git/git_diff",
        "@git/git_diff_staged",
        "@git/git_diff_unstaged",
        "@git/git_log",
        "@git/git_show",
        "@git/git_status",
        "fs_read",
        "glob",
        "grep",
        "knowledge",
        "use_subagent",
        "web_fetch",
        "web_search"
    ],

    "tools": ["*"],

    "hooks": {
        "agentSpawn": [],
        "preToolUse": [
            {
                "matcher": "*",
                "command": "~/.dotfiles/etc/kiro-cli/hooks/block-env-files.sh"
            }
        ]
    },

    "toolsSettings": {
        "aws": {
            "allowedServices": []
        },
        "shell": {
            "allowedCommands": [
                "mdbook .*",
                "pre-commit .*",
                "(GIT_PAGER=cat )?git log.*",
                "git status.*",
                "ls( .*)?",
                "cat .*",
                "cd .*",
                "grep .*",
                "awk .*",
                "head .*",
                "tail .*",
                "tree( .*)?",
                "wc .*"
            ],
            "deniedCommands": [
                "awk .*\\.env.*",
                "cat .*\\.env.*",
                "grep .*\\.env.*",
                "head .*\\.env.*",
                "sed .*\\.env.*",
                "tail .*\\.env.*",
                "rm .*",
                "sudo .*",
                "chmod .*",
                "chown .*",
                "git add.*",
                "git commit.*",
                "docker .*",
                "kubectl .*"
            ]
        },
        "write": {
            "allowedPaths": [
                "~/projects/**",
                "~/repositories/**",
                "~/.dotfiles/**",
                "./**"
            ],
            "deniedPaths": [
                "/etc/**",
                "/usr/**",
                "/bin/**",
                "/sbin/**",
                "/System/**"
            ]
        },
        "grep": {
            "allowedPaths": ["~/projects/**", "~/repositories/**", "~/.dotfiles/**", "./**"],
            "deniedPaths": ["/etc/**", "/usr/**", "/bin/**", "/sbin/**", "/System/**", "**/.env", "**/.env.*"]
        },
        "glob": {
            "allowedPaths": ["~/projects/**", "~/repositories/**", "~/.dotfiles/**", "./**"],
            "deniedPaths": ["/etc/**", "/usr/**", "/bin/**", "/sbin/**", "/System/**", "**/.env", "**/.env.*"]
        },
        "subagent": {
            "availableAgents": ["default", "github", "jira"],
            "trustedAgents": ["default"]
        },
        "web_fetch": {
            "trusted": [
                ".*rust-lang\\.io.*",
                ".*github\\.com.*",
                ".*mdbook.*",
                ".*adr\\.github\\.io.*",
                ".*readthedocs\\.io.*",
                ".*docs\\..*"
            ],
            "blocked": [
                ".*pastebin\\.com.*"
            ]
        }
    },

    "includeMcpJson": true
}
