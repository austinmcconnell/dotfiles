{
    "name": "docs",
    "description": "Documentation project specialist with mdBook expertise and best practices",
    "prompt": "file://./docs-prompt.md",

    "resources": [
        "file://~/.dotfiles/etc/kiro-cli/steering/documentation/**/*.md",
        "file://~/.dotfiles/etc/kiro-cli/steering/security/env-file-protection.md",
        "file://.kiro/steering/**/*.md",
        "file://AGENTS.md",
        "file://README.md",
        "file://SUMMARY.md",
        "file://book.toml",
        "skill://.kiro/skills/**/SKILL.md",
        "skill://~/.kiro/skills/documentation/**/SKILL.md",
        "skill://~/.kiro/skills/shared/**/SKILL.md"
    ],

    "allowedTools": [
        "@filesystem/create_directory",
        "@filesystem/get_file_info",
        "@filesystem/list_allowed_directories",
        "@filesystem/read_multiple_files",
        "@filesystem/read_text_file",
        "@filesystem/search_files",
        "@git/git_status",
        "execute_bash",
        "fs_read",
        "fs_write",
        "glob",
        "grep",
        "web_search"
    ],

    "tools": ["*"],

    "hooks": {
        "agentSpawn": [],
        "preToolUse": []
    },

    "toolsSettings": {
        "shell": {
            "allowedCommands": [
                "mdbook .*",
                "pre-commit .*",
                "git status.*",
                "ls .*",
                "cat .*",
                "grep .*",
                "awk .*",
                "head .*",
                "tail .*",
                "wc .*"
            ],
            "deniedCommands": [
                "awk .*\\.env.*",
                "cat .*\\.env.*",
                "grep .*\\.env.*",
                "head .*\\.env.*",
                "sed .*\\.env.*",
                "tail .*\\.env.*",
                "rm .*",
                "sudo .*",
                "chmod .*",
                "chown .*",
                "git add.*",
                "git commit.*",
                "docker .*",
                "kubectl .*"
            ]
        },
        "write": {
            "allowedPaths": [
                "~/projects/**",
                "~/repositories/**",
                "~/.dotfiles/**",
                "./**"
            ],
            "deniedPaths": [
                "/etc/**",
                "/usr/**",
                "/bin/**",
                "/sbin/**",
                "/System/**"
            ]
        },
        "grep": {
            "allowedPaths": ["~/projects/**", "~/repositories/**", "~/.dotfiles/**", "./**"],
            "deniedPaths": ["/etc/**", "/usr/**", "/bin/**", "/sbin/**", "/System/**", "**/.env", "**/.env.*"]
        },
        "glob": {
            "allowedPaths": ["~/projects/**", "~/repositories/**", "~/.dotfiles/**", "./**"],
            "deniedPaths": ["/etc/**", "/usr/**", "/bin/**", "/sbin/**", "/System/**", "**/.env", "**/.env.*"]
        },
        "web_fetch": {
            "trusted": [
                ".*rust-lang\\.io.*",
                ".*github\\.com.*",
                ".*mdbook.*",
                ".*adr\\.github\\.io.*",
                ".*readthedocs\\.io.*",
                ".*docs\\..*"
            ],
            "blocked": [
                ".*pastebin\\.com.*"
            ]
        }
    },

    "includeMcpJson": false
}
