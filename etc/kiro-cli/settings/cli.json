{
  "autocomplete.disable": true,
  "autocomplete.insertSpaceAutomatically": true,
  "chat.defaultAgent": "default",
  "codeWhisperer.shareCodeWhispererContentWithAWS": false,
  "inline.enabled": false,
  "mcp.loadedBefore": true,
  "telemetry.enabled": false,
  "chat.enableKnowledge": true,
  "knowledge.defaultIncludePatterns": [
    "*.md",
    "*.sh",
    "*.zsh",
    "*.vim",
    "*.py",
    "*.json",
    "*.yaml",
    "*.yml"
  ],
  "knowledge.defaultExcludePatterns": [
    "*.log",
    "node_modules",
    ".git",
    "*.pyc",
    "__pycache__",
    ".antidote",
    ".zsh_plugins.zsh",
    "*.zwc"
  ],
  "knowledge.maxFiles": 2000,
  "knowledge.indexType": "best",
  "chat.diffTool": "delta --paging=never",
  "chat.enableCheckpoint": true,
  "chat.enableContextUsageIndicator": true,
  "chat.enableHistoryHints": false,
  "chat.enableNotifications": true,
  "chat.enablePromptHints": false,
  "chat.enableSubagent": true,
  "chat.enableThinking": true,
  "chat.enableTodoList": true,
  "chat.greeting.enabled": false,
  "cleanup.periodDays": 90,
  "hooks.showStatus": true
}