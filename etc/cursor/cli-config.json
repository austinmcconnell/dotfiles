{
    "version": 1,
    "permissions": {
        "allow": [
            "Shell(cat *)",
            "Shell(chmod +x *)",
            "Shell(command -v *)",
            "Shell(dirname *)",
            "Shell(echo *)",
            "Shell(find *)",
            "Shell(gh api *)",
            "Shell(gh issue *)",
            "Shell(gh pr *)",
            "Shell(gh run *)",
            "Shell(git branch*)",
            "Shell(git diff*)",
            "Shell(git log*)",
            "Shell(git ls-files*)",
            "Shell(git rev-parse *)",
            "Shell(git show*)",
            "Shell(git status*)",
            "Shell(grep *)",
            "Shell(head *)",
            "Shell(jq *)",
            "Shell(ls *)",
            "Shell(ls)",
            "Shell(man *)",
            "Shell(mkdir -p *)",
            "Shell(pre-commit run *)",
            "Shell(pwd)",
            "Shell(pylint *)",
            "Shell(sed *)",
            "Shell(sort *)",
            "Shell(tail *)",
            "Shell(tree *)",
            "Shell(tree)",
            "Shell(wc *)",
            "Shell(which *)",
            "Shell(whoami)"
        ],
        "deny": [
            "Shell(cat *.env*)",
            "Shell(grep *.env*)",
            "Shell(find *.env*)",
            "Shell(head *.env*)",
            "Shell(tail *.env*)",
            "Shell(sed *.env*)",
            "Shell(gh auth *)",
            "Shell(gh issue close *)",
            "Shell(gh issue delete *)",
            "Shell(gh pr close *)",
            "Shell(gh pr merge *)",
            "Shell(gh release *)",
            "Shell(gh repo create *)",
            "Shell(gh repo delete*)",
            "Shell(gh secret *)",
            "Shell(gh variable *)",
            "Shell(gh workflow run *)",
            "Shell(sudo *)",
            "Shell(rm *)",
            "Shell(rmdir *)",
            "Shell(kubectl apply *)",
            "Shell(kubectl create *)",
            "Shell(kubectl delete *)",
            "Read(**/.env*)",
            "Read(**/*.key)",
            "Read(**/*.pem)",
            "Read(**/credentials*)",
            "Write(/etc/**)",
            "Write(/usr/**)",
            "Write(/bin/**)",
            "Write(/sbin/**)",
            "Write(/System/**)"
        ]
    }
}
