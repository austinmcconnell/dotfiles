#!/bin/bash

set -euo pipefail

# Validates commit messages against conventional commits format.
# Skips validation for merge, squash, fixup, and amend commits.
# Bypassed with --no-verify (e.g., the wip alias uses this).

COMMIT_MSG_FILE="$1"

# Save message on failure so prepare-commit-msg can restore it next time.
SAVED_MSG="$(git rev-parse --git-dir)/COMMIT_MSG_SAVED"
ec=0
trap 'ec=$?; if [[ $ec -ne 0 ]]; then cp "$COMMIT_MSG_FILE" "$SAVED_MSG"; else rm -f "$SAVED_MSG"; fi' EXIT

# Configuration
PREFIX="[commit-msg]"
MAX_SUBJECT_LENGTH=72
MAX_BODY_LINE_LENGTH=72
VALID_TYPES="feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert"

# Strip comments (lines starting with #) and verbose diff output.
# With commit.verbose=true, git appends the diff below a scissor line
# (# --- >8 ---) or below the comment block. Strip both.
message=$(sed '/^#/d; /^diff --git /,$d' "$COMMIT_MSG_FILE")

# Dedent: remove common leading whitespace (handles pasted indented text).
# Find the minimum indent across non-empty lines, then strip that many chars.
min_indent=""
min_indent_set=false
while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    indent="${line%%[! ]*}"
    if [[ "$min_indent_set" == false ]] || [[ ${#indent} -lt ${#min_indent} ]]; then
        min_indent="$indent"
        min_indent_set=true
    fi
done <<<"$message"
if [[ -n "$min_indent" ]]; then
    # ${var//} doesn't support anchored ^
    # shellcheck disable=SC2001
    message=$(echo "$message" | sed "s/^${min_indent}//")
fi

# Trim trailing whitespace from each line.
# ${var//} doesn't support [[:space:]] or $
# shellcheck disable=SC2001
message=$(echo "$message" | sed 's/[[:space:]]*$//')

# Write cleaned message back so git uses the dedented/trimmed version.
echo "$message" >"$COMMIT_MSG_FILE"

# Get the subject line (first non-empty line)
subject=$(echo "$message" | sed '/^$/d' | head -1)

# Skip empty messages (git will abort these anyway)
if [[ -z "$subject" ]]; then
    exit 0
fi

# Skip merge, fixup, squash, and amend commits
skip_pattern="^(Merge |Squash |fixup!|squash!|amend!)"
if [[ "$subject" =~ $skip_pattern ]]; then
    exit 0
fi

# Pattern: type(scope)!: subject  or  type!: subject  or  type: subject
# Lowercase types only — spec rule 15 says case-insensitive, but that targets
# parsers, not authoring tools. Matches commitlint and ecosystem conventions.
conv_pattern="^($VALID_TYPES)(\([a-zA-Z0-9-]+\))?\!?: .+"

if ! [[ "$subject" =~ $conv_pattern ]]; then
    echo "$PREFIX Invalid commit message format." >&2
    echo "" >&2
    echo "  $subject" >&2
    echo "" >&2
    echo "Expected: type(scope): description" >&2
    echo "Types: ${VALID_TYPES//|/, }" >&2
    echo "Example: feat(auth): add OAuth2 login support" >&2
    exit 1
fi

# Extract the description (text after ": ")
description="${subject#*: }"

# Check: no period at end
if [[ "$description" == *. ]]; then
    echo "$PREFIX Subject must not end with a period." >&2
    echo "" >&2
    echo "  $subject" >&2
    exit 1
fi

# Check: lowercase after colon
first_char="${description:0:1}"
if [[ "$first_char" =~ [A-Z] ]]; then
    echo "$PREFIX Description must start with lowercase." >&2
    echo "" >&2
    echo "  $subject" >&2
    exit 1
fi

# Check: subject length
if [[ ${#subject} -gt $MAX_SUBJECT_LENGTH ]]; then
    echo "$PREFIX Subject is ${#subject} chars (max $MAX_SUBJECT_LENGTH)." >&2
    echo "" >&2
    echo "  $subject" >&2
    exit 1
fi

# Check: blank line between subject and body
second_line=$(echo "$message" | sed -n '2p')
if [[ -n "$second_line" ]]; then
    echo "$PREFIX Must have a blank line between subject and body." >&2
    exit 1
fi

# Check: body lines wrapped at 72 chars
line_num=0
while IFS= read -r line; do
    line_num=$((line_num + 1))
    # Skip subject and blank separator
    if [[ $line_num -le 2 ]]; then
        continue
    fi
    if [[ ${#line} -gt $MAX_BODY_LINE_LENGTH ]]; then
        echo "$PREFIX Body line $line_num is ${#line} chars (max $MAX_BODY_LINE_LENGTH)." >&2
        echo "" >&2
        echo "  $line" >&2
        exit 1
    fi
done <<<"$message"

# Check: bullet continuation lines must be indented 2 spaces.
# A continuation is a non-blank line that follows a "- " bullet (or another
# continuation) and doesn't start a new bullet or footer.
in_bullet=false
line_num=0
while IFS= read -r line; do
    line_num=$((line_num + 1))
    if [[ $line_num -le 2 ]]; then
        continue
    fi
    if [[ -z "$line" ]]; then
        in_bullet=false
        continue
    fi
    if [[ "$line" == "- "* ]]; then
        in_bullet=true
        continue
    fi
    if [[ "$in_bullet" == true ]]; then
        if ! [[ "$line" == "  "* ]]; then
            echo "$PREFIX Bullet continuation must be indented 2 spaces." >&2
            echo "" >&2
            echo "  $line" >&2
            echo "" >&2
            echo "Example:" >&2
            echo "  - First line of bullet" >&2
            echo "    continuation indented 2 spaces" >&2
            exit 1
        fi
    fi
done <<<"$message"

# Check: BREAKING CHANGE footer must be uppercase (conventional commits spec)
bad_breaking_change="^[Bb][Rr][Ee][Aa][Kk][Ii][Nn][Gg][ -][Cc][Hh][Aa][Nn][Gg][Ee]:"
good_breaking_change="^BREAKING[ -]CHANGE:"
while IFS= read -r line; do
    if [[ "$line" =~ $bad_breaking_change ]] && ! [[ "$line" =~ $good_breaking_change ]]; then
        echo "$PREFIX Use uppercase 'BREAKING CHANGE:' (conventional commits spec)." >&2
        echo "" >&2
        echo "  $line" >&2
        exit 1
    fi
done <<<"$message"

# Check: footer structure (conventional commits spec rules 8-9)
# Footers are the block of lines after the last blank line (excluding subject separator).
# Valid footer: "Token: value", "Token #value", or "BREAKING CHANGE: value"
# Token must be a word using - for spaces (exception: BREAKING CHANGE).
# Lines that continue a multi-line footer value (no token/separator) are allowed.
footer_token="^([A-Za-z-]+|BREAKING CHANGE)(: | #)"
hash_separator=" #"
last_blank=0
total_lines=$(echo "$message" | wc -l | tr -d ' ')

# Find the last blank line after the subject separator (line 2)
line_num=0
while IFS= read -r line; do
    line_num=$((line_num + 1))
    if [[ $line_num -le 2 ]]; then
        continue
    fi
    if [[ -z "$line" ]]; then
        last_blank=$line_num
    fi
done <<<"$message"

# If there's a blank line after the body, validate the footer block.
# Only enter footer mode if the first non-empty line after the blank
# looks like a footer (contains ": " or " #"). Lines starting with
# "- " are body bullets, not footers.
if [[ $last_blank -gt 2 && $last_blank -lt $total_lines ]]; then
    in_footer=false
    line_num=0
    while IFS= read -r line; do
        line_num=$((line_num + 1))
        if [[ $line_num -le $last_blank ]]; then
            continue
        fi
        # Detect footer start on first non-empty line
        if [[ "$in_footer" == false ]]; then
            if [[ -z "$line" ]]; then
                continue
            fi
            # Bullet points are body text, not footers
            if [[ "$line" == "- "* ]]; then
                break
            fi
            # Must contain a footer separator to be a footer block
            if [[ "$line" =~ ": " ]] || [[ "$line" =~ $hash_separator ]]; then
                in_footer=true
            else
                break
            fi
        fi
        # Skip empty lines and continuation lines (indented)
        if [[ -z "$line" ]] || [[ "$line" =~ ^[[:space:]] ]]; then
            continue
        fi
        # If line contains a separator, it should be a valid footer
        if [[ "$line" =~ ": " ]] || [[ "$line" =~ $hash_separator ]]; then
            if ! [[ "$line" =~ $footer_token ]]; then
                echo "$PREFIX Invalid footer format." >&2
                echo "" >&2
                echo "  $line" >&2
                echo "" >&2
                echo "Expected: Token: value  or  Token${hash_separator}value" >&2
                echo "Use hyphens in tokens (e.g., Jira-issue, Reviewed-by)" >&2
                exit 1
            fi
        fi
    done <<<"$message"
fi
