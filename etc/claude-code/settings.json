{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "permissions": {
        "allow": [
            "Bash(cat *)",
            "Bash(command -v *)",
            "Bash(dirname *)",
            "Bash(echo *)",
            "Bash(find *)",
            "Bash(gh api *)",
            "Bash(gh issue list*)",
            "Bash(gh issue view*)",
            "Bash(gh pr list*)",
            "Bash(gh pr view*)",
            "Bash(gh run *)",
            "Bash(git branch*)",
            "Bash(git diff*)",
            "Bash(git log*)",
            "Bash(git ls-files*)",
            "Bash(git rev-parse *)",
            "Bash(git show*)",
            "Bash(git status*)",
            "Bash(grep *)",
            "Bash(head *)",
            "Bash(jq *)",
            "Bash(ls *)",
            "Bash(ls)",
            "Bash(man *)",
            "Bash(mkdir -p *)",
            "Bash(pre-commit run *)",
            "Bash(pwd)",
            "Bash(pylint *)",
            "Bash(sed *)",
            "Bash(sort *)",
            "Bash(tail *)",
            "Bash(tree *)",
            "Bash(tree)",
            "Bash(wc *)",
            "Bash(which *)",
            "Bash(whoami)"
        ],
        "deny": [
            "Read(./.env*)",
            "Read(**/.env*)",
            "Read(**/*.key)",
            "Read(**/*.pem)",
            "Read(**/credentials*)",
            "Bash(awk *.env*)",
            "Bash(cat *.env*)",
            "Bash(find *.env*)",
            "Bash(grep *.env*)",
            "Bash(head *.env*)",
            "Bash(sed *.env*)",
            "Bash(tail *.env*)",
            "Edit(/etc/**)",
            "Edit(/usr/**)",
            "Edit(/bin/**)",
            "Edit(/sbin/**)",
            "Edit(/System/**)",
            "Bash(chmod *)",
            "Bash(chown *)",
            "Bash(cp /*)",
            "Bash(crontab -e*)",
            "Bash(crontab -r*)",
            "Bash(dd *)",
            "Bash(docker exec --privileged *)",
            "Bash(docker run --privileged *)",
            "Bash(fdisk *)",
            "Bash(gh auth *)",
            "Bash(gh issue close *)",
            "Bash(gh issue delete *)",
            "Bash(gh label create *)",
            "Bash(gh label delete *)",
            "Bash(gh label edit *)",
            "Bash(gh pr close *)",
            "Bash(gh pr merge *)",
            "Bash(gh release create *)",
            "Bash(gh release delete *)",
            "Bash(gh repo create *)",
            "Bash(gh repo delete*)",
            "Bash(gh repo edit *)",
            "Bash(gh repo fork *)",
            "Bash(gh run cancel *)",
            "Bash(gh run rerun *)",
            "Bash(gh secret *)",
            "Bash(gh variable *)",
            "Bash(gh workflow disable *)",
            "Bash(gh workflow run *)",
            "Bash(git add .)",
            "Bash(git add -A*)",
            "Bash(git add --all*)",
            "Bash(init *)",
            "Bash(kill -9 *)",
            "Bash(killall *)",
            "Bash(kubectl apply *)",
            "Bash(kubectl create *)",
            "Bash(kubectl delete *)",
            "Bash(kubectl patch *)",
            "Bash(kubectl replace *)",
            "Bash(mkfs *)",
            "Bash(mount *)",
            "Bash(mv /*)",
            "Bash(pkill *)",
            "Bash(reboot)",
            "Bash(rm *)",
            "Bash(rmdir *)",
            "Bash(service *)",
            "Bash(shutdown *)",
            "Bash(sudo *)",
            "Bash(systemctl *)",
            "Bash(trash *)",
            "Bash(umount *)"
        ]
    },
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "*",
                "hooks": [
                    {
                        "type": "command",
                        "command": "~/.dotfiles/etc/ai/hooks/block-env-files.sh",
                        "timeout": 5
                    }
                ]
            }
        ],
        "PostToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "~/.dotfiles/etc/ai/hooks/audit-shell-commands.sh",
                        "async": true,
                        "timeout": 10
                    }
                ]
            }
        ],
        "Stop": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "~/.dotfiles/etc/ai/hooks/notify-stop.sh",
                        "timeout": 5
                    }
                ]
            }
        ],
        "Notification": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "~/.dotfiles/etc/ai/hooks/notify-attention.sh",
                        "timeout": 5
                    }
                ]
            }
        ]
    }
}
