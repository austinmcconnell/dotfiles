set showtabline=2                              " always show tabline
let g:lightline#bufferline#show_number = 1     " show buffer number
let g:lightline#bufferline#modified = ' +'     " modified indicator
let g:lightline#bufferline#smart_path = 1      " disambiguate duplicate filenames
let g:lightline#bufferline#min_buffer_count = 2 " hide tabline with single buffer
