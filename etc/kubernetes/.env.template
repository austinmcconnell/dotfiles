# Local domain for ingress hostnames (e.g. prometheus.local.dev)
LOCAL_DOMAIN=local.dev

# Non-Helm resources (applied via kubectl in setup.sh)
ENABLE_LIMIT_RANGE=true
ENABLE_RESOURCE_QUOTA=true

# Path to corporate CA certificate (e.g. Cloudflare/zScaler MITM cert)
# Only needed on work machines behind a TLS-intercepting proxy
# CORP_CERT_PATH=/etc/ssl/cloudflare.crt
